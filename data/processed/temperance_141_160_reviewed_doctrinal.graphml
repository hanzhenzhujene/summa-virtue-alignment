<graph edgedefault="directed"><node id="concept.abstinence">
  <data key="d0">concept.abstinence</data>
  <data key="d1">Abstinence</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue moderating food by reason.</data>
  <data key="d5"></data>
</node>
<node id="concept.adultery_lust">
  <data key="d0">concept.adultery_lust</data>
  <data key="d1">Adultery</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Adultery as treated within the species of lust in q.154.</data>
  <data key="d5"></data>
</node>
<node id="concept.anger">
  <data key="d0">concept.anger</data>
  <data key="d1">Anger</data>
  <data key="d2">passion</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Passion of the irascible appetite concerning injury and vindication.</data>
  <data key="d5"></data>
</node>
<node id="concept.anger_vice">
  <data key="d0">concept.anger_vice</data>
  <data key="d1">Anger (Vice-Level)</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Anger insofar as it becomes sinful by setting aside the order of reason.</data>
  <data key="d5"></data>
</node>
<node id="concept.beauty_of_virtue">
  <data key="d0">concept.beauty_of_virtue</data>
  <data key="d1">Beauty / Comeliness of Virtue</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The honorable beauty or comeliness especially associated with temperance and honesty.</data>
  <data key="d5"></data>
</node>
<node id="concept.cardinal_virtue">
  <data key="d0">concept.cardinal_virtue</data>
  <data key="d1">Cardinal Virtue</data>
  <data key="d2">virtue</data>
  <data key="d3">seed</data>
  <data key="d4">Principal moral virtue around which others are ordered.</data>
  <data key="d5"></data>
</node>
<node id="concept.chastity">
  <data key="d0">concept.chastity</data>
  <data key="d1">Chastity</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue by which reason chastises concupiscence in venereal pleasures.</data>
  <data key="d5"></data>
</node>
<node id="concept.clemency">
  <data key="d0">concept.clemency</data>
  <data key="d1">Clemency</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue that mitigates punishment under the rule of reason.</data>
  <data key="d5"></data>
</node>
<node id="concept.continence">
  <data key="d0">concept.continence</data>
  <data key="d1">Continence</data>
  <data key="d2">habit</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Reason's resistance to vehement evil desires without the full ease of perfect temperance.</data>
  <data key="d5"></data>
</node>
<node id="concept.cruelty">
  <data key="d0">concept.cruelty</data>
  <data key="d1">Cruelty</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The vice opposed to clemency by exceeding due severity in punishment.</data>
  <data key="d5"></data>
</node>
<node id="concept.disgrace">
  <data key="d0">concept.disgrace</data>
  <data key="d1">Disgrace</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Disgrace as the feared deformity opposed to temperance and related virtue.</data>
  <data key="d5"></data>
</node>
<node id="concept.drink">
  <data key="d0">concept.drink</data>
  <data key="d1">Drink</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Drink as matter for sobriety and drunkenness in the temperance tract.</data>
  <data key="d5"></data>
</node>
<node id="concept.drunkenness">
  <data key="d0">concept.drunkenness</data>
  <data key="d1">Drunkenness</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Immoderate use of wine or intoxicating drink resulting in loss of reason.</data>
  <data key="d5"></data>
</node>
<node id="concept.fasting">
  <data key="d0">concept.fasting</data>
  <data key="d1">Fasting</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A virtuous act of abstinence undertaken under the rule of reason.</data>
  <data key="d5"></data>
</node>
<node id="concept.fear_of_lord_gift">
  <data key="d0">concept.fear_of_lord_gift</data>
  <data key="d1">Gift of Fear of the Lord</data>
  <data key="d2">gift_holy_spirit</data>
  <data key="d3">seed</data>
  <data key="d4">Gift of the Holy Spirit producing reverential fear before God.</data>
  <data key="d5"></data>
</node>
<node id="concept.food">
  <data key="d0">concept.food</data>
  <data key="d1">Food</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Food as matter for abstinence, fasting, and gluttony within the temperance tract.</data>
  <data key="d5"></data>
</node>
<node id="concept.gluttony">
  <data key="d0">concept.gluttony</data>
  <data key="d1">Gluttony</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Inordinate desire of eating and drinking opposed to abstinence.</data>
  <data key="d5"></data>
</node>
<node id="concept.honesty_temperance">
  <data key="d0">concept.honesty_temperance</data>
  <data key="d1">Honesty (Temperance Tract)</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Honesty as the honorable comeliness of virtue and an integral part of temperance in this tract.</data>
  <data key="d5"></data>
</node>
<node id="concept.incest_lust">
  <data key="d0">concept.incest_lust</data>
  <data key="d1">Incest</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Incest as treated within the species of lust in q.154.</data>
  <data key="d5"></data>
</node>
<node id="concept.incontinence">
  <data key="d0">concept.incontinence</data>
  <data key="d1">Incontinence</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Failure to stand by reason under vehement passion, especially in pleasures of touch and secondarily in anger.</data>
  <data key="d5"></data>
</node>
<node id="concept.insensibility_temperance">
  <data key="d0">concept.insensibility_temperance</data>
  <data key="d1">Insensibility (Against Temperance)</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Defective refusal of pleasures that nature requires in due measure, opposed to temperance in q.142.</data>
  <data key="d5"></data>
</node>
<node id="concept.intemperance">
  <data key="d0">concept.intemperance</data>
  <data key="d1">Intemperance</data>
  <data key="d2">vice</data>
  <data key="d3">seed</data>
  <data key="d4">Vice opposed to temperance.</data>
  <data key="d5"></data>
</node>
<node id="concept.lust">
  <data key="d0">concept.lust</data>
  <data key="d1">Lust</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Disordered seeking of venereal pleasure against right reason.</data>
  <data key="d5"></data>
</node>
<node id="concept.meekness">
  <data key="d0">concept.meekness</data>
  <data key="d1">Meekness</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue moderating the passion of anger under reason.</data>
  <data key="d5"></data>
</node>
<node id="concept.modesty_general">
  <data key="d0">concept.modesty_general</data>
  <data key="d1">Modesty (General)</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The annexed virtue moderating lesser matters where restraint is easier than in temperance proper.</data>
  <data key="d5"></data>
</node>
<node id="concept.nocturnal_pollution">
  <data key="d0">concept.nocturnal_pollution</data>
  <data key="d1">Nocturnal Pollution</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Nocturnal venereal pollution as treated in q.154 a.5.</data>
  <data key="d5"></data>
</node>
<node id="concept.outward_moderation">
  <data key="d0">concept.outward_moderation</data>
  <data key="d1">Outward Moderation</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The broader field of lesser matters moderated by modesty in q.160.</data>
  <data key="d5"></data>
</node>
<node id="concept.parts_of_lust">
  <data key="d0">concept.parts_of_lust</data>
  <data key="d1">Parts / Species of Lust</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The tract-level division of lust into distinct species treated in q.154.</data>
  <data key="d5"></data>
</node>
<node id="concept.parts_of_temperance_general">
  <data key="d0">concept.parts_of_temperance_general</data>
  <data key="d1">Parts of Temperance (General Taxonomy)</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The tract-level teaching that temperance has integral, subjective, and potential parts.</data>
  <data key="d5"></data>
</node>
<node id="concept.pleasures_of_touch">
  <data key="d0">concept.pleasures_of_touch</data>
  <data key="d1">Pleasures of Touch</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The proper matter of temperance in the restricted sense emphasized in q.141.</data>
  <data key="d5"></data>
</node>
<node id="concept.punishment">
  <data key="d0">concept.punishment</data>
  <data key="d1">Punishment</data>
  <data key="d2">process</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Punishment as the matter clemency mitigates under the rule of reason.</data>
  <data key="d5"></data>
</node>
<node id="concept.purity_temperance">
  <data key="d0">concept.purity_temperance</data>
  <data key="d1">Purity (Temperance Tract)</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Purity insofar as it moderates pleasures incidental to venereal acts in the temperance tract.</data>
  <data key="d5"></data>
</node>
<node id="concept.rape_lust">
  <data key="d0">concept.rape_lust</data>
  <data key="d1">Rape</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Rape as treated within the species or grave acts of lust in q.154.</data>
  <data key="d5"></data>
</node>
<node id="concept.reason">
  <data key="d0">concept.reason</data>
  <data key="d1">Reason</data>
  <data key="d2">faculty</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Reason as rule and measure of human acts.</data>
  <data key="d5"></data>
</node>
<node id="concept.sacrilege_lust">
  <data key="d0">concept.sacrilege_lust</data>
  <data key="d1">Sacrilege (Lust Tract)</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Sacrilege insofar as sacred persons or things are violated by venereal sin in q.154.</data>
  <data key="d5"></data>
</node>
<node id="concept.savagery_brutality">
  <data key="d0">concept.savagery_brutality</data>
  <data key="d1">Savagery / Brutality</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Bestial or savage attack distinct from cruelty properly so called in q.159 a.2.</data>
  <data key="d5"></data>
</node>
<node id="concept.seduction_lust">
  <data key="d0">concept.seduction_lust</data>
  <data key="d1">Seduction</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Seduction as treated among the species or tracted cases of lust in q.154.</data>
  <data key="d5"></data>
</node>
<node id="concept.sexual_pleasure">
  <data key="d0">concept.sexual_pleasure</data>
  <data key="d1">Venereal / Sexual Pleasure</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The venereal matter treated by chastity, virginity, lust, and the parts of lust.</data>
  <data key="d5"></data>
</node>
<node id="concept.shamefacedness">
  <data key="d0">concept.shamefacedness</data>
  <data key="d1">Shamefacedness</data>
  <data key="d2">passion</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The fear of disgrace that stands as an integral part of temperance while falling short of perfect virtue.</data>
  <data key="d5"></data>
</node>
<node id="concept.simple_fornication">
  <data key="d0">concept.simple_fornication</data>
  <data key="d1">Simple Fornication</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The union of an unmarried man and an unmarried woman treated as a species of lust in q.154.</data>
  <data key="d5"></data>
</node>
<node id="concept.sin">
  <data key="d0">concept.sin</data>
  <data key="d1">Sin</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Bad human act contrary to due rule and measure.</data>
  <data key="d5"></data>
</node>
<node id="concept.sobriety">
  <data key="d0">concept.sobriety</data>
  <data key="d1">Sobriety</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue moderating intoxicating drink for the safeguard of reason.</data>
  <data key="d5"></data>
</node>
<node id="concept.temperance">
  <data key="d0">concept.temperance</data>
  <data key="d1">Temperance</data>
  <data key="d2">virtue</data>
  <data key="d3">seed</data>
  <data key="d4">The cardinal virtue moderating attractions of pleasure.</data>
  <data key="d5"></data>
</node>
<node id="concept.unnatural_vice_lust">
  <data key="d0">concept.unnatural_vice_lust</data>
  <data key="d1">Vice Against Nature</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Venereal acts from which generation cannot follow, treated as a species of lust in q.154.</data>
  <data key="d5"></data>
</node>
<node id="concept.venereal_touches_kisses">
  <data key="d0">concept.venereal_touches_kisses</data>
  <data key="d1">Venereal Touches / Kisses</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Disordered venereal touching and kissing treated in q.154 a.4.</data>
  <data key="d5"></data>
</node>
<node id="concept.vice">
  <data key="d0">concept.vice</data>
  <data key="d1">Vice</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Vice considered as privative disorder contrary to virtue.</data>
  <data key="d5"></data>
</node>
<node id="concept.virginity">
  <data key="d0">concept.virginity</data>
  <data key="d1">Virginity</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The tract's virtue or state of perpetual integrity ordered to freedom from venereal experience.</data>
  <data key="d5"></data>
</node>
<node id="concept.virtue">
  <data key="d0">concept.virtue</data>
  <data key="d1">Virtue</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Generic virtue as good operative perfection.</data>
  <data key="d5">Do not collapse generic virtue into a specific virtue without explicit passage support.</data>
</node>
