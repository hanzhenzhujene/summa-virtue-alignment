  <data key="d6">edge.potential_parts.concept.meekness.potential_part_of.concept.temperance</data>
  <data key="d7">concept.meekness</data>
  <data key="d8">Meekness</data>
  <data key="d9">virtue</data>
  <data key="d10">potential_part_of</data>
