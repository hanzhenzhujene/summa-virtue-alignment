  <data key="d15">st.ii-ii.q148.a001.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">aid to be a sin through being contrary to virtue . Wherefore it is evident that gluttony is a sin .</data>
  <data key="d18">reviewed_doctrinal</data>
