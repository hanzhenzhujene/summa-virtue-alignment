<graph edgedefault="directed"><node id="concept.ambition">
  <data key="d0">concept.ambition</data>
  <data key="d1">Ambition</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Inordinate desire of honor opposed to well-ordered magnanimity.</data>
  <data key="d5"></data>
</node>
<node id="concept.arduous_work">
  <data key="d0">concept.arduous_work</data>
  <data key="d1">Arduous / Difficult Work</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The difficult good work whose completion and endurance are explicitly attached to fortitude and the gift of fortitude.</data>
  <data key="d5"></data>
</node>
<node id="concept.beatitude_hunger_for_justice">
  <data key="d0">concept.beatitude_hunger_for_justice</data>
  <data key="d1">Beatitude of Hunger and Thirst for Justice</data>
  <data key="d2">beatitude</data>
  <data key="d3">seed</data>
  <data key="d4">Beatitude pronounced on those hungering and thirsting for justice.</data>
  <data key="d5"></data>
</node>
<node id="concept.charity">
  <data key="d0">concept.charity</data>
  <data key="d1">Charity</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Theological virtue of friendship with God.</data>
  <data key="d5">Do not auto-normalize bare 'love' to charity outside clearly theological context.</data>
</node>
<node id="concept.confidence">
  <data key="d0">concept.confidence</data>
  <data key="d1">Confidence</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A strength of hope that the magnanimous person has in difficult good.</data>
  <data key="d5"></data>
</node>
<node id="concept.constancy_fortitude">
  <data key="d0">concept.constancy_fortitude</data>
  <data key="d1">Constancy</data>
  <data key="d2">habit</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The fortitude-related habit of persisting in good against external hindrances rather than the mere duration of the act.</data>
  <data key="d5">Kept distinct from perseverance even though q.137 closely compares the two.</data>
</node>
<node id="concept.continuance_in_good">
  <data key="d0">concept.continuance_in_good</data>
  <data key="d1">Continuance in Good</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The continued accomplishment of a good work over time that is distinctive of perseverance.</data>
  <data key="d5"></data>
</node>
<node id="concept.counsel_gift">
  <data key="d0">concept.counsel_gift</data>
  <data key="d1">Gift of Counsel</data>
  <data key="d2">gift_holy_spirit</data>
  <data key="d3">seed</data>
  <data key="d4">Gift of the Holy Spirit perfecting right counsel in action.</data>
  <data key="d5"></data>
</node>
<node id="concept.effeminacy_perseverance">
  <data key="d0">concept.effeminacy_perseverance</data>
  <data key="d1">Effeminacy</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The vice by which one forsakes a good on account of difficulties that cannot be endured, especially through softness regarding pleasure.</data>
  <data key="d5"></data>
</node>
<node id="concept.fortitude">
  <data key="d0">concept.fortitude</data>
  <data key="d1">Fortitude</data>
  <data key="d2">virtue</data>
  <data key="d3">seed</data>
  <data key="d4">The cardinal virtue governing firmness in difficulties and dangers.</data>
  <data key="d5"></data>
</node>
<node id="concept.fortitude_gift">
  <data key="d0">concept.fortitude_gift</data>
  <data key="d1">Gift of Fortitude</data>
  <data key="d2">gift_holy_spirit</data>
  <data key="d3">seed</data>
  <data key="d4">Gift of the Holy Spirit strengthening endurance in arduous good.</data>
  <data key="d5"></data>
</node>
<node id="concept.glory">
  <data key="d0">concept.glory</data>
  <data key="d1">Glory</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The manifest approval or public clarity of someone's good in the sight of others.</data>
  <data key="d5"></data>
</node>
<node id="concept.god">
  <data key="d0">concept.god</data>
  <data key="d1">God</data>
  <data key="d2">object</data>
  <data key="d3">seed</data>
  <data key="d4">God as the object or term of theological virtue and charity.</data>
  <data key="d5"></data>
</node>
<node id="concept.goods_of_fortune">
  <data key="d0">concept.goods_of_fortune</data>
  <data key="d1">Goods of Fortune</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">External goods such as riches, power, and friends that can instrumentally conduce to magnanimity.</data>
  <data key="d5"></data>
</node>
<node id="concept.grace">
  <data key="d0">concept.grace</data>
  <data key="d1">Grace</data>
  <data key="d2">grace</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Grace as the supernatural help needed beyond fallen nature.</data>
  <data key="d5">Generic grace remains distinct from operating and cooperating grace unless the text names the subtype.</data>
</node>
<node id="concept.great_expenditure">
  <data key="d0">concept.great_expenditure</data>
  <data key="d1">Great Expenditure</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The scale of spending proportionate to a great work in the magnificence tract.</data>
  <data key="d5"></data>
</node>
<node id="concept.great_work">
  <data key="d0">concept.great_work</data>
  <data key="d1">Great Work</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The kind of work whose becoming execution and proportionate expense belong to magnificence.</data>
  <data key="d5"></data>
</node>
<node id="concept.grievous_evil">
  <data key="d0">concept.grievous_evil</data>
  <data key="d1">Grievous Evil / Hardship</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The difficult evil or sorrow endured by patience and, analogously, by fortitude.</data>
  <data key="d5"></data>
</node>
<node id="concept.honor_recognition">
  <data key="d0">concept.honor_recognition</data>
  <data key="d1">Honor as Recognition</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Honor considered as public recognition or attestation of excellence, especially as the matter of magnanimity.</data>
  <data key="d5"></data>
</node>
<node id="concept.longanimity_fortitude">
  <data key="d0">concept.longanimity_fortitude</data>
  <data key="d1">Longanimity</data>
  <data key="d2">habit</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The habit of tending toward a good that lies far off, compared with patience without being simply identical to it.</data>
  <data key="d5">Kept tract-local because q.136 explicitly resists collapsing longanimity into patience.</data>
</node>
<node id="concept.magnanimity">
  <data key="d0">concept.magnanimity</data>
  <data key="d1">Magnanimity</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The fortitude-related virtue by which a person deems himself worthy of great honors and great things in due proportion.</data>
  <data key="d5">Keep distinct from magnificence: magnanimity is honor- and worthiness-related rather than expenditure-related.</data>
</node>
<node id="concept.magnificence">
  <data key="d0">concept.magnificence</data>
  <data key="d1">Magnificence</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The fortitude-related virtue of producing great works with proportionate expenditure.</data>
  <data key="d5">Keep distinct from magnanimity: magnificence concerns great works and expenditure, not honor as such.</data>
</node>
<node id="concept.meanness_magnificence">
  <data key="d0">concept.meanness_magnificence</data>
  <data key="d1">Meanness</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The vice of spending less than a great work requires, thereby failing proportion.</data>
  <data key="d5"></data>
</node>
<node id="concept.patience">
  <data key="d0">concept.patience</data>
  <data key="d1">Patience</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The annexed virtue by which one bears grievous evils with an equal mind for the sake of good.</data>
  <data key="d5">Keep distinct from fruit-level patience in later correspondence work.</data>
</node>
<node id="concept.perseverance_virtue">
  <data key="d0">concept.perseverance_virtue</data>
  <data key="d1">Perseverance (Fortitude Part)</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue by which one persists long in a good work despite the difficulty arising from its continuance.</data>
  <data key="d5">This tract-local concept is kept distinct from the broader act-level `concept.perseverance` already present from the I-II grace pilot.</data>
</node>
<node id="concept.pertinacity_perseverance">
  <data key="d0">concept.pertinacity_perseverance</data>
  <data key="d1">Pertinacity</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The vice by which one persists more than one ought, exceeding the mean of perseverance.</data>
  <data key="d5"></data>
</node>
<node id="concept.precepts_of_fortitude">
  <data key="d0">concept.precepts_of_fortitude</data>
  <data key="d1">Precepts of Fortitude</data>
  <data key="d2">precept</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The precept-complex by which Divine Law directs fortitude itself toward adherence to God and brave endurance.</data>
  <data key="d5"></data>
</node>
<node id="concept.precepts_of_fortitude_parts">
  <data key="d0">concept.precepts_of_fortitude_parts</data>
  <data key="d1">Precepts of Patience and Perseverance</data>
  <data key="d2">precept</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The precept-complex by which Divine Law gives directions concerning patience and perseverance as annexed virtues.</data>
  <data key="d5"></data>
</node>
<node id="concept.presumption_magnanimity">
  <data key="d0">concept.presumption_magnanimity</data>
  <data key="d1">Presumption (Against Magnanimity)</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The vice of exceeding one's own ability by attempting what is above one's power in the magnanimity tract.</data>
  <data key="d5"></data>
</node>
<node id="concept.pusillanimity">
  <data key="d0">concept.pusillanimity</data>
  <data key="d1">Pusillanimity</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The vice of shrinking from great things proportionate to one's worth.</data>
  <data key="d5"></data>
</node>
<node id="concept.security_assurance">
  <data key="d0">concept.security_assurance</data>
  <data key="d1">Security / Assurance</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Freedom from fear considered in relation to magnanimity and fortitude.</data>
  <data key="d5"></data>
</node>
<node id="concept.sin">
  <data key="d0">concept.sin</data>
  <data key="d1">Sin</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Bad human act contrary to due rule and measure.</data>
  <data key="d5"></data>
</node>
<node id="concept.vainglory">
  <data key="d0">concept.vainglory</data>
  <data key="d1">Vainglory</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Inordinate desire for empty glory, opposed in this tract to magnanimity's right use of honor and glory.</data>
  <data key="d5"></data>
</node>
<node id="concept.vice">
  <data key="d0">concept.vice</data>
  <data key="d1">Vice</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Vice considered as privative disorder contrary to virtue.</data>
  <data key="d5"></data>
</node>
<node id="concept.virtue">
  <data key="d0">concept.virtue</data>
  <data key="d1">Virtue</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Generic virtue as good operative perfection.</data>
  <data key="d5">Do not collapse generic virtue into a specific virtue without explicit passage support.</data>
</node>
<node id="concept.waste_magnificence">
  <data key="d0">concept.waste_magnificence</data>
  <data key="d1">Waste (Banausia / Consumptio)</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The vice of spending more than a work requires, thereby exceeding due proportion in the magnificence tract.</data>
  <data key="d5"></data>
</node>
<node id="concept.worthiness">
  <data key="d0">concept.worthiness</data>
  <data key="d1">Worthiness</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Proportionate worth or desert in relation to great things and great honors.</data>
  <data key="d5"></data>
</node>
