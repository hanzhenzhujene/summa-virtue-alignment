<graph edgedefault="directed"><node id="concept.authority_related_due">
  <data key="d0">concept.authority_related_due</data>
  <data key="d1">Authority-Related Due</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">What is due because another rightly commands under divinely ordered authority.</data>
  <data key="d5"></data>
</node>
<node id="concept.benefaction">
  <data key="d0">concept.benefaction</data>
  <data key="d1">Benefaction</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A favor or freely bestowed benefit generating a moral debt of gratitude.</data>
  <data key="d5"></data>
</node>
<node id="concept.benefaction_related_due">
  <data key="d0">concept.benefaction_related_due</data>
  <data key="d1">Benefaction-Related Due</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">What is due because one has received a freely bestowed benefit from another.</data>
  <data key="d5"></data>
</node>
<node id="concept.benefactor_role">
  <data key="d0">concept.benefactor_role</data>
  <data key="d1">Benefactor Role</data>
  <data key="d2">role</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Role-level category for one from whom a recipient has received a benefit.</data>
  <data key="d5"></data>
</node>
<node id="concept.command">
  <data key="d0">concept.command</data>
  <data key="d1">Command</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Practical act applying counsel and judgment to action.</data>
  <data key="d5"></data>
</node>
<node id="concept.country">
  <data key="d0">concept.country</data>
  <data key="d1">Country</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The fatherland or country as an origin-context and object of piety after parents.</data>
  <data key="d5"></data>
</node>
<node id="concept.disobedience">
  <data key="d0">concept.disobedience</data>
  <data key="d1">Disobedience</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The sin of refusing obedience due to God or to a superior in rightful command.</data>
  <data key="d5"></data>
</node>
<node id="concept.dulia">
  <data key="d0">concept.dulia</data>
  <data key="d1">Dulia</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A species of observance rendering due service to a human lord under a created mode of superiority.</data>
  <data key="d5"></data>
</node>
<node id="concept.excellence_related_due">
  <data key="d0">concept.excellence_related_due</data>
  <data key="d1">Excellence-Related Due</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">What is due because another excels in dignity, superiority, or governing station.</data>
  <data key="d5"></data>
</node>
<node id="concept.gratitude">
  <data key="d0">concept.gratitude</data>
  <data key="d1">Gratitude</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue giving thanks to a benefactor for a favor received.</data>
  <data key="d5"></data>
</node>
<node id="concept.honor">
  <data key="d0">concept.honor</data>
  <data key="d1">Honor</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The act of acknowledging excellence through fitting signs.</data>
  <data key="d5"></data>
</node>
<node id="concept.human_lord_role">
  <data key="d0">concept.human_lord_role</data>
  <data key="d1">Human Lord Role</data>
  <data key="d2">role</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Role-level category for a created lord to whom due service is paid under dulia.</data>
  <data key="d5"></data>
</node>
<node id="concept.ingratitude">
  <data key="d0">concept.ingratitude</data>
  <data key="d1">Ingratitude</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The sin opposed to gratitude by deficiency in acknowledging, praising, or repaying a favor.</data>
  <data key="d5"></data>
</node>
<node id="concept.justice">
  <data key="d0">concept.justice</data>
  <data key="d1">Justice</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Moral virtue rendering acts and agents right in relation to another.</data>
  <data key="d5"></data>
</node>
<node id="concept.obedience">
  <data key="d0">concept.obedience</data>
  <data key="d1">Obedience</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue by which one follows a superior's command according to divinely established order.</data>
  <data key="d5"></data>
</node>
<node id="concept.observance">
  <data key="d0">concept.observance</data>
  <data key="d1">Observance</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue paying honor and service to persons who excel in dignity.</data>
  <data key="d5"></data>
</node>
<node id="concept.origin_related_due">
  <data key="d0">concept.origin_related_due</data>
  <data key="d1">Origin-Related Due</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">What is due because another stands as a proximate principle of one's being or upbringing.</data>
  <data key="d5"></data>
</node>
<node id="concept.parent_role">
  <data key="d0">concept.parent_role</data>
  <data key="d1">Parent Role</data>
  <data key="d2">role</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Role-level category for parents as proximate principles of being and upbringing.</data>
  <data key="d5"></data>
</node>
<node id="concept.person_in_dignity_role">
  <data key="d0">concept.person_in_dignity_role</data>
  <data key="d1">Person in Dignity</data>
  <data key="d2">role</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Role-level category for one who excels in dignity and governance.</data>
  <data key="d5"></data>
</node>
<node id="concept.piety">
  <data key="d0">concept.piety</data>
  <data key="d1">Piety</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue rendering due worship and service to parents and country as proximate principles of being and government.</data>
  <data key="d5"></data>
</node>
<node id="concept.prior_wrong">
  <data key="d0">concept.prior_wrong</data>
  <data key="d1">Prior Wrong</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A prior wrong or sin to which rectificatory response may be due.</data>
  <data key="d5"></data>
</node>
<node id="concept.punishment">
  <data key="d0">concept.punishment</data>
  <data key="d1">Punishment</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A penal infliction restoring order or acting medicinally when rightly imposed.</data>
  <data key="d5"></data>
</node>
<node id="concept.rectification">
  <data key="d0">concept.rectification</data>
  <data key="d1">Rectification</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The restoration of order after prior wrong by due punitive or corrective response.</data>
  <data key="d5"></data>
</node>
<node id="concept.rectificatory_due">
  <data key="d0">concept.rectificatory_due</data>
  <data key="d1">Rectificatory Due</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">What is due because a prior wrong calls for correction, restraint, or punitive restoration of order.</data>
  <data key="d5"></data>
</node>
<node id="concept.service">
  <data key="d0">concept.service</data>
  <data key="d1">Service</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Fitting service rendered to another according to due relation.</data>
  <data key="d5"></data>
</node>
<node id="concept.superior_role">
  <data key="d0">concept.superior_role</data>
  <data key="d1">Superior Role</data>
  <data key="d2">role</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Role-level category for one who commands or governs others in due order.</data>
  <data key="d5"></data>
</node>
<node id="concept.vengeance">
  <data key="d0">concept.vengeance</data>
  <data key="d1">Vengeance</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue seeking due penal correction or restraint in response to prior wrong.</data>
  <data key="d5"></data>
</node>
