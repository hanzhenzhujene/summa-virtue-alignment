  <data key="d7">st.ii-ii.q104.a002</data>
  <data key="d8">II-II q.104 a.2 — Is obedience a special virtue?</data>
  <data key="d9">article</data>
  <data key="d10">treated_in</data>
  <data key="d11">concept.command</data>
