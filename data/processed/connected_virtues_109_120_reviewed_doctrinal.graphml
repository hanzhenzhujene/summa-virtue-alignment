  <data key="d15">st.ii-ii.q118.a003.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">man loves or desires riches too much, or takes too much pleasure in them, even if he be unwilling to steal. On this way covetousness is opposed to liberality, which moderates these affections, as stated above ( 117, 2, ad 3, 3, ad 3, 6 ). On this sense covetousness is spoken of ( 2 Corinthians 9:5 ): "That they woul</data>
  <data key="d18">reviewed_doctrinal</data>
  <data key="d19">external_goods</data>
</edge>
<edge source="concept.covetousness" target="concept.retaining" id="edge.concept.covetousness.has_act.concept.retaining">
  <data key="d6">edge.concept.covetousness.has_act.concept.retaining</data>
  <data key="d7">concept.covetousness</data>
  <data key="d8">Covetousness</data>
  <data key="d9">vice</data>
  <data key="d10">has_act</data>
  <data key="d11">concept.retaining</data>
  <data key="d12">Retaining</data>
