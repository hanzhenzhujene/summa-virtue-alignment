  <data key="d2">sin_type</data>
  <data key="d3">seed</data>
  <data key="d4">Sinful movement contrary to hope by judging pardon or salvation unavailable from God.</data>
  <data key="d5"></data>
</node>
<node id="concept.discord">
  <data key="d0">concept.discord</data>
  <data key="d1">Discord</data>
  <data key="d2">sin_type</data>
  <data key="d3">seed</data>
