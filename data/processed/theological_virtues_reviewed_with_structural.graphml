  <data key="d10">treated_in</data>
  <data key="d11">concept.despair_sin</data>
  <data key="d12">Despair (Sin)</data>
  <data key="d13">sin_type</data>
  <data key="d14">ann.st-ii-ii-q020-treated-in-concept-despair-sin-st-ii-ii-q020-a001-resp</data>
  <data key="d15">st.ii-ii.q020.a001.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">ement of hope, which is in conformity with the true opinion, is praiseworthy and virtuous , so the contrary movement of despair , which is in conformity with the false opinion about God , is vicious and sinful .</data>
  <data key="d18">reviewed_structural_editorial</data>
</edge>
<edge source="st.ii-ii.q020" target="concept.hope" id="edge.st.ii-ii.q020.treated_in.concept.hope">
  <data key="d6">edge.st.ii-ii.q020.treated_in.concept.hope</data>
  <data key="d7">st.ii-ii.q020</data>
  <data key="d8">II-II q.20 — Despair</data>
  <data key="d9">question</data>
  <data key="d10">treated_in</data>
  <data key="d11">concept.hope</data>
  <data key="d12">Hope</data>
  <data key="d13">virtue</data>
  <data key="d14">ann.st-ii-ii-q020-treated-in-concept-hope-st-ii-ii-q020-a001-resp</data>
  <data key="d15">st.ii-ii.q020.a001.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">repentant sinner, or that He does not turn sinners to Himself by sanctifying grace . Therefore, just as the movement of hope, which is in conformity with the true opinion, is praiseworthy and virtuous , so the contrary movement of despair , which is in conformity with the false opini</data>
  <data key="d18">reviewed_structural_editorial</data>
</edge>
<edge source="st.ii-ii.q020" target="st.ii-ii.q020.a001" id="structural.st.ii-ii.q020.contains.st.ii-ii.q020.a001">
  <data key="d6">structural.st.ii-ii.q020.contains.st.ii-ii.q020.a001</data>
  <data key="d7">st.ii-ii.q020</data>
  <data key="d8">II-II q.20 — Despair</data>
