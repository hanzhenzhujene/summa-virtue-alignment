</edge>
<edge source="st.ii-ii.q022" target="st.ii-ii.q022.a002" id="structural.st.ii-ii.q022.contains.st.ii-ii.q022.a002">
  <data key="d6">structural.st.ii-ii.q022.contains.st.ii-ii.q022.a002</data>
  <data key="d7">st.ii-ii.q022</data>
  <data key="d8">II-II q.22 — The precepts relating to hope and fear</data>
