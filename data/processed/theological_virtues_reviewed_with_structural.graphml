  <data key="d15">st.ii-ii.q003.a001.obj1</data>
  <data key="d16">structural_editorial</data>
  <data key="d17">It would seem that confession is not an act of faith . For the same act does not belong to different virtues . Now confession belongs to penance of which it is a part. Therefore it is not an act of faith .</data>
  <data key="d18">structural</data>
</edge>
<edge source="st.ii-ii.q003" target="st.ii-ii.q003.a002" id="structural.st.ii-ii.q003.contains.st.ii-ii.q003.a002">
