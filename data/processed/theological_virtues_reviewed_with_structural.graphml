  <data key="d15">st.ii-ii.q024.a001.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">ll is good under the universal aspect of good , according as it can be apprehended by the intellect . Now the object of charity is not a sensible good , but the Divine good which is known by the intellect alone. Therefore the subject of charity is not the sensitive, but the intellective</data>
  <data key="d18">reviewed_structural_editorial</data>
</edge>
<edge source="st.ii-ii.q024" target="concept.holy_spirit" id="edge.st.ii-ii.q024.treated_in.concept.holy_spirit">
  <data key="d6">edge.st.ii-ii.q024.treated_in.concept.holy_spirit</data>
  <data key="d7">st.ii-ii.q024</data>
