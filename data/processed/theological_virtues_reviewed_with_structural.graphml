  <data key="d0">concept.contention</data>
  <data key="d1">Contention</data>
  <data key="d2">sin_type</data>
  <data key="d3">seed</data>
  <data key="d4">Contrariety of speech in a disordered or truth-disclaiming manner.</data>
  <data key="d5"></data>
</node>
