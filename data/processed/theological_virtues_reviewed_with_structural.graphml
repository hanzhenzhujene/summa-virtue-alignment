  <data key="d14">ann.st-ii-ii-q016-treated-in-concept-precepts-of-faith-knowledge-and-understanding-st-ii-ii-q016-a001-resp</data>
  <data key="d15">st.ii-ii.q016.a001.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">expounding the words: "This is My commandment" ( John 15:12 ) says (Tract. lxxxiii in Joan.) that we have received many precepts of faith . In the Old Law , however, the secret things of faith were not to be set before the people, wherefore, presupposing their faith in one God , no other precepts</data>
  <data key="d18">reviewed_structural_editorial</data>
</edge>
<edge source="st.ii-ii.q016" target="st.ii-ii.q016.a001" id="structural.st.ii-ii.q016.contains.st.ii-ii.q016.a001">
  <data key="d6">structural.st.ii-ii.q016.contains.st.ii-ii.q016.a001</data>
  <data key="d7">st.ii-ii.q016</data>
  <data key="d8">II-II q.16 — The precepts of faith, knowledge and understanding</data>
  <data key="d9">question</data>
  <data key="d10">contains_article</data>
  <data key="d11">st.ii-ii.q016.a001</data>
  <data key="d12">II-II q.16 a.1 — The precepts concerning faith</data>
