  <data key="d0">concept.scandal</data>
  <data key="d1">Scandal</data>
  <data key="d2">sin_type</data>
  <data key="d3">seed</data>
  <data key="d4">Something less rightly done or said that occasions another's spiritual downfall.</data>
  <data key="d5"></data>
</node>
