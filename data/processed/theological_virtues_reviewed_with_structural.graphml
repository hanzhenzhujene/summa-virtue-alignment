  <data key="d0">concept.presumption</data>
  <data key="d1">Presumption</data>
  <data key="d2">sin_type</data>
  <data key="d3">seed</data>
  <data key="d4">Immoderate hope relying on God or self in a disordered way.</data>
  <data key="d5"></data>
</node>
