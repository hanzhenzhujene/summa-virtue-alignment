<edge source="st.ii-ii.q015" target="st.ii-ii.q015.a001" id="structural.st.ii-ii.q015.contains.st.ii-ii.q015.a001">
  <data key="d6">structural.st.ii-ii.q015.contains.st.ii-ii.q015.a001</data>
  <data key="d7">st.ii-ii.q015</data>
  <data key="d8">II-II q.15 — The vices opposed to knowledge and understanding</data>
