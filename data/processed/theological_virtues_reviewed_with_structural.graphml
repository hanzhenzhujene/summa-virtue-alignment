  <data key="d0">concept.confession_of_faith</data>
  <data key="d1">Confession of Faith</data>
  <data key="d2">act_type</data>
  <data key="d3">seed</data>
  <data key="d4">The outward verbal confession of what is held by faith.</data>
  <data key="d5"></data>
</node>
