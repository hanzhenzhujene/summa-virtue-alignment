  <data key="d0">concept.concord</data>
  <data key="d1">Concord</data>
  <data key="d2">act_type</data>
  <data key="d3">seed</data>
  <data key="d4">Agreement of hearts directed together by charity.</data>
  <data key="d5"></data>
</node>
