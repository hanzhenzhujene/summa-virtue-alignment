  <data key="d15">st.ii-ii.q002.a003.obj1</data>
  <data key="d16">structural_editorial</data>
  <data key="d17">It would seem unnecessary for salvation to believe anything above the natural reason . For the salvation and perfection of a thing seem to be sufficiently insured by its natural endowments. Now matters of faith , surpass</data>
  <data key="d18">structural</data>
</edge>
<edge source="st.ii-ii.q002" target="st.ii-ii.q002.a004" id="structural.st.ii-ii.q002.contains.st.ii-ii.q002.a004">
