  <data key="d12">Charity</data>
  <data key="d13">virtue</data>
  <data key="d14">ann.st-ii-ii-q029-treated-in-concept-charity-st-ii-ii-q029-a003-resp</data>
  <data key="d15">st.ii-ii.q029.a003.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">ther results from one's own appetite being united with the appetite of another: and each of these unions is effected by charity —the first, in so far as man loves God with his whole heart, by referring all things to Him, so that all his desires tend to one object—the second, in so far a</data>
  <data key="d18">reviewed_structural_editorial</data>
</edge>
<edge source="st.ii-ii.q029" target="concept.peace" id="edge.st.ii-ii.q029.treated_in.concept.peace">
  <data key="d6">edge.st.ii-ii.q029.treated_in.concept.peace</data>
  <data key="d7">st.ii-ii.q029</data>
  <data key="d8">II-II q.29 — Peace</data>
  <data key="d9">question</data>
  <data key="d10">treated_in</data>
  <data key="d11">concept.peace</data>
  <data key="d12">Peace</data>
  <data key="d13">act_type</data>
