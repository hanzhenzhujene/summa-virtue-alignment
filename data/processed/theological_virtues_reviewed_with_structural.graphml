  <data key="d0">concept.first_truth</data>
  <data key="d1">First Truth</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Formal object of faith considered under divine revelation.</data>
  <data key="d5"></data>
</node>
