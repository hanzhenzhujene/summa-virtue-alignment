  <data key="d7">st.ii-ii.q026</data>
  <data key="d8">II-II q.26 — The order of charity</data>
  <data key="d9">question</data>
  <data key="d10">contains_article</data>
  <data key="d11">st.ii-ii.q026.a006</data>
  <data key="d12">II-II q.26 a.6 — Should he love one neighbor more than another?</data>
