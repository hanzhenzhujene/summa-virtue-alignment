</edge>
<edge source="st.ii-ii.q003" target="st.ii-ii.q003.a001" id="structural.st.ii-ii.q003.contains.st.ii-ii.q003.a001">
  <data key="d6">structural.st.ii-ii.q003.contains.st.ii-ii.q003.a001</data>
  <data key="d7">st.ii-ii.q003</data>
  <data key="d8">II-II q.3 — The outward act of faith</data>
  <data key="d9">question</data>
  <data key="d10">contains_article</data>
  <data key="d11">st.ii-ii.q003.a001</data>
  <data key="d12">II-II q.3 a.1 — Is confession an act of faith?</data>
