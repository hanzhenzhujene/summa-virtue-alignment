  <data key="d15">st.ii-ii.q002.a004.obj1</data>
  <data key="d16">structural_editorial</data>
  <data key="d17">It would seem unnecessary to believe those things which can be proved by natural reason . For nothing is superfluous in God's works, much less even than in the works of nature . Now it is superfluous to employ other mean</data>
  <data key="d18">structural</data>
</edge>
<edge source="st.ii-ii.q002" target="st.ii-ii.q002.a005" id="structural.st.ii-ii.q002.contains.st.ii-ii.q002.a005">
