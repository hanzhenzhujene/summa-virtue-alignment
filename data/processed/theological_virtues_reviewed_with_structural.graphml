  <data key="d13">article</data>
  <data key="d14"></data>
  <data key="d15">st.ii-ii.q024.a003.resp</data>
  <data key="d16">structural_editorial</data>
  <data key="d17">The quantity of a thing depends on the proper cause of that thing, since the more universal cause produces a greater effect. Now, since charity surpasses the proportion of human nature , as stated above ( Article 2 ) it </data>
  <data key="d18">structural</data>
</edge>
<edge source="st.ii-ii.q024" target="st.ii-ii.q024.a004" id="structural.st.ii-ii.q024.contains.st.ii-ii.q024.a004">
