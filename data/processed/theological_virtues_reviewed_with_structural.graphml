<edge source="st.ii-ii.q028" target="concept.joy" id="edge.st.ii-ii.q028.treated_in.concept.joy">
  <data key="d6">edge.st.ii-ii.q028.treated_in.concept.joy</data>
  <data key="d7">st.ii-ii.q028</data>
  <data key="d8">II-II q.28 — Joy</data>
  <data key="d9">question</data>
  <data key="d10">treated_in</data>
  <data key="d11">concept.joy</data>
  <data key="d12">Joy</data>
