  <data key="d7">concept.simony</data>
  <data key="d8">Simony</data>
  <data key="d9">sin_type</data>
  <data key="d10">misuses_sacred_object</data>
  <data key="d11">concept.sacrament</data>
  <data key="d12">Sacrament</data>
  <data key="d13">object</data>
  <data key="d14">ann.concept-simony-misuses-sacred-object-concept-sacrament-st-ii-ii-q100-a002-resp</data>
  <data key="d15">st.ii-ii.q100.a002.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">the altar?" Accordingly we must answer that to receive money for the spiritual grace of the sacraments , is the sin of simony, which cannot be excused by any custom whatever, since "custom does not prevail over natural or divine law " [Cap. Cum tanto, de Consuetud.; cf. I-II:97:3 . No</data>
  <data key="d18">reviewed_doctrinal</data>
</edge>
<edge source="concept.simony" target="concept.spiritual_action" id="edge.concept.simony.misuses_sacred_object.concept.spiritual_action">
  <data key="d6">edge.concept.simony.misuses_sacred_object.concept.spiritual_action</data>
  <data key="d7">concept.simony</data>
  <data key="d8">Simony</data>
  <data key="d9">sin_type</data>
  <data key="d10">misuses_sacred_object</data>
