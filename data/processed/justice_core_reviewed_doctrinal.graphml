<graph edgedefault="directed"><node id="concept.accuser_role">
  <data key="d0">concept.accuser_role</data>
  <data key="d1">Accuser</data>
  <data key="d2">role</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The prosecuting role in a criminal accusation.</data>
  <data key="d5">Role-level concept only; do not instantiate individual accusers.</data>
</node>
<node id="concept.advocate_role">
  <data key="d0">concept.advocate_role</data>
  <data key="d1">Advocate</data>
  <data key="d2">role</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The role of legal counsel who defends a party in court.</data>
  <data key="d5">Role-level concept only; do not instantiate individual advocates.</data>
</node>
<node id="concept.anger">
  <data key="d0">concept.anger</data>
  <data key="d1">Anger</data>
  <data key="d2">passion</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Passion of the irascible appetite concerning injury and vindication.</data>
  <data key="d5"></data>
</node>
<node id="concept.assault">
  <data key="d0">concept.assault</data>
  <data key="d1">Assault or Blows</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Injury to the body by blows that inflict pain without destroying the member.</data>
  <data key="d5"></data>
</node>
<node id="concept.backbiting">
  <data key="d0">concept.backbiting</data>
  <data key="d1">Backbiting</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Secret verbal injury that blackens a person's good name.</data>
  <data key="d5"></data>
</node>
<node id="concept.bodily_integrity">
  <data key="d0">concept.bodily_integrity</data>
  <data key="d1">Bodily Integrity</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The wholeness of the body harmed by maiming and bodily assault.</data>
  <data key="d5"></data>
</node>
<node id="concept.calumnious_defense">
  <data key="d0">concept.calumnious_defense</data>
  <data key="d1">Calumnious Defense</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A defense that uses falsehood or calumny rather than truth.</data>
  <data key="d5"></data>
</node>
<node id="concept.charity">
  <data key="d0">concept.charity</data>
  <data key="d1">Charity</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Theological virtue of friendship with God.</data>
  <data key="d5">Do not auto-normalize bare 'love' to charity outside clearly theological context.</data>
</node>
<node id="concept.cheating">
  <data key="d0">concept.cheating</data>
  <data key="d1">Cheating in Exchange</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Fraudulent or unequal exchange in buying and selling.</data>
  <data key="d5"></data>
</node>
<node id="concept.common_good">
  <data key="d0">concept.common_good</data>
  <data key="d1">Common Good</data>
  <data key="d2">end</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Good of the whole community rather than of a private individual alone.</data>
  <data key="d5"></data>
</node>
<node id="concept.commutative_justice">
  <data key="d0">concept.commutative_justice</data>
  <data key="d1">Commutative Justice</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The species of particular justice concerned with equality in exchanges between persons.</data>
  <data key="d5"></data>
</node>
<node id="concept.cursing">
  <data key="d0">concept.cursing</data>
  <data key="d1">Cursing</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Speaking evil of another by way of command or desire.</data>
  <data key="d5"></data>
</node>
<node id="concept.defendant_role">
  <data key="d0">concept.defendant_role</data>
  <data key="d1">Defendant</data>
  <data key="d2">role</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The role of the accused person in judicial proceedings.</data>
  <data key="d5">Role-level concept only; do not instantiate individual defendants.</data>
</node>
<node id="concept.derision">
  <data key="d0">concept.derision</data>
  <data key="d1">Derision</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Injury by jest or mockery directed to another's shame.</data>
  <data key="d5"></data>
</node>
<node id="concept.dishonest_advocacy">
  <data key="d0">concept.dishonest_advocacy</data>
  <data key="d1">Dishonest Advocacy</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Advocacy that knowingly assists an unjust cause.</data>
  <data key="d5"></data>
</node>
<node id="concept.distributive_justice">
  <data key="d0">concept.distributive_justice</data>
  <data key="d1">Distributive Justice</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The species of particular justice concerned with proportional distributions from the whole to its parts.</data>
  <data key="d5"></data>
</node>
<node id="concept.dominion_right">
  <data key="d0">concept.dominion_right</data>
  <data key="d1">Right of Dominion</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A species of right arising from ownership or lordship.</data>
  <data key="d5"></data>
</node>
<node id="concept.extortionate_advocacy">
  <data key="d0">concept.extortionate_advocacy</data>
  <data key="d1">Extortionate Advocacy</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The unjust exaction of an immoderate fee by an advocate.</data>
  <data key="d5"></data>
</node>
<node id="concept.fairness_in_distribution">
  <data key="d0">concept.fairness_in_distribution</data>
  <data key="d1">Fairness in Distribution</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The proportional equality proper to distributive justice.</data>
  <data key="d5"></data>
</node>
<node id="concept.fairness_in_exchange">
  <data key="d0">concept.fairness_in_exchange</data>
  <data key="d1">Fairness in Exchange</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The equality proper to commutative justice and market exchange.</data>
  <data key="d5"></data>
</node>
<node id="concept.false_accusation">
  <data key="d0">concept.false_accusation</data>
  <data key="d1">False Accusation</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">An accusation that wrongfully injures the accused and the common good.</data>
  <data key="d5"></data>
</node>
<node id="concept.false_witness">
  <data key="d0">concept.false_witness</data>
  <data key="d1">False Witness</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">False testimony given under oath in a judicial matter.</data>
  <data key="d5"></data>
</node>
<node id="concept.friendship">
  <data key="d0">concept.friendship</data>
  <data key="d1">Friendship</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The social bond chiefly injured by tale-bearing.</data>
  <data key="d5"></data>
</node>
<node id="concept.general_justice">
  <data key="d0">concept.general_justice</data>
  <data key="d1">General Justice</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Justice directing acts of virtue to the common good.</data>
  <data key="d5"></data>
</node>
<node id="concept.honor">
  <data key="d0">concept.honor</data>
  <data key="d1">Honor</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The social good openly injured by reviling and derision.</data>
  <data key="d5"></data>
</node>
<node id="concept.injustice">
  <data key="d0">concept.injustice</data>
  <data key="d1">Injustice</data>
  <data key="d2">vice</data>
  <data key="d3">seed</data>
  <data key="d4">Vice opposed to justice.</data>
  <data key="d5"></data>
</node>
<node id="concept.judge_role">
  <data key="d0">concept.judge_role</data>
  <data key="d1">Judge</data>
  <data key="d2">role</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The judicial role empowered to pronounce sentence publicly.</data>
  <data key="d5">Role-level concept only; do not instantiate individual judges.</data>
</node>
<node id="concept.judgment">
  <data key="d0">concept.judgment</data>
  <data key="d1">Judgment</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The act of determining what is just in a case.</data>
  <data key="d5"></data>
</node>
<node id="concept.judicial_process">
  <data key="d0">concept.judicial_process</data>
  <data key="d1">Judicial Process</data>
  <data key="d2">process</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The public legal procedure within which judgment, accusation, testimony, and defense occur.</data>
  <data key="d5"></data>
</node>
<node id="concept.just_price">
  <data key="d0">concept.just_price</data>
  <data key="d1">Just Price</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The equality of value that should govern buying and selling.</data>
  <data key="d5"></data>
</node>
<node id="concept.justice">
  <data key="d0">concept.justice</data>
  <data key="d1">Justice</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Moral virtue rendering acts and agents right in relation to another.</data>
  <data key="d5"></data>
</node>
<node id="concept.law">
  <data key="d0">concept.law</data>
  <data key="d1">Law</data>
  <data key="d2">law</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Law as ordinance of reason for the common good.</data>
  <data key="d5">Generic law is kept distinct from named law-types unless the text is explicit.</data>
</node>
<node id="concept.life">
  <data key="d0">concept.life</data>
  <data key="d1">Life</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The domain of bodily life harmed by unjust killing.</data>
  <data key="d5"></data>
</node>
<node id="concept.maiming">
  <data key="d0">concept.maiming</data>
  <data key="d1">Maiming</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Injury that destroys bodily integrity by depriving a member.</data>
  <data key="d5"></data>
</node>
<node id="concept.natural_right">
  <data key="d0">concept.natural_right</data>
  <data key="d1">Natural Right</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Right grounded in the nature of the thing and not merely in human enactment.</data>
  <data key="d5"></data>
</node>
<node id="concept.omission">
  <data key="d0">concept.omission</data>
  <data key="d1">Omission</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Sin by failing to do a due good.</data>
  <data key="d5"></data>
</node>
<node id="concept.particular_justice">
  <data key="d0">concept.particular_justice</data>
  <data key="d1">Particular Justice</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Justice directing a person in relation to other individuals.</data>
  <data key="d5"></data>
</node>
<node id="concept.paternal_right">
  <data key="d0">concept.paternal_right</data>
  <data key="d1">Paternal Right</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A species of right reflecting a father's relation to what belongs to the household.</data>
  <data key="d5"></data>
</node>
<node id="concept.personal_liberty">
  <data key="d0">concept.personal_liberty</data>
  <data key="d1">Personal Liberty</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The domain harmed by unjust detention or imprisonment.</data>
  <data key="d5"></data>
</node>
<node id="concept.positive_right">
  <data key="d0">concept.positive_right</data>
  <data key="d1">Positive Right</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Right arising from human agreement, enactment, or institution.</data>
  <data key="d5"></data>
</node>
<node id="concept.private_execution">
  <data key="d0">concept.private_execution</data>
  <data key="d1">Private Execution</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The wrongful private taking of punitive killing into one's own hands.</data>
  <data key="d5"></data>
</node>
<node id="concept.property">
  <data key="d0">concept.property</data>
  <data key="d1">Property</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The domain of possession and external goods harmed by theft and robbery.</data>
  <data key="d5"></data>
</node>
<node id="concept.public_execution">
  <data key="d0">concept.public_execution</data>
  <data key="d1">Public Execution of Evildoers</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The punitive killing Aquinas treats as belonging to public authority for the common good.</data>
  <data key="d5"></data>
</node>
<node id="concept.rash_judgment">
  <data key="d0">concept.rash_judgment</data>
  <data key="d1">Rash Judgment</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Judgment rendered from insufficient signs or suspicion rather than due certitude.</data>
  <data key="d5"></data>
</node>
<node id="concept.rendering_due">
  <data key="d0">concept.rendering_due</data>
  <data key="d1">Rendering Due</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Proper act of justice in giving each one what is due.</data>
  <data key="d5"></data>
</node>
<node id="concept.reputation">
  <data key="d0">concept.reputation</data>
  <data key="d1">Reputation</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The good name secretly injured by backbiting.</data>
  <data key="d5"></data>
</node>
<node id="concept.respect_of_persons">
  <data key="d0">concept.respect_of_persons</data>
  <data key="d1">Respect of Persons</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Preference given to persons on irrelevant grounds, contrary to distributive justice.</data>
  <data key="d5"></data>
</node>
<node id="concept.restitution">
  <data key="d0">concept.restitution</data>
  <data key="d1">Restitution</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The act by which commutative equality is re-established through restoration.</data>
  <data key="d5"></data>
</node>
<node id="concept.reviling">
  <data key="d0">concept.reviling</data>
  <data key="d1">Reviling</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Verbal injury that dishonors another openly.</data>
  <data key="d5"></data>
</node>
<node id="concept.right">
  <data key="d0">concept.right</data>
  <data key="d1">Right</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The just or right thing that stands as the object of justice.</data>
  <data key="d5">Keep this juridical sense distinct from moral uprightness in general.</data>
</node>
<node id="concept.right_of_nations">
  <data key="d0">concept.right_of_nations</data>
  <data key="d1">Right of Nations</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The right common among peoples and treated by Aquinas in relation to natural and positive right.</data>
  <data key="d5"></data>
</node>
<node id="concept.robbery">
  <data key="d0">concept.robbery</data>
  <data key="d1">Robbery</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The violent taking of another's property.</data>
  <data key="d5"></data>
</node>
<node id="concept.suicide">
  <data key="d0">concept.suicide</data>
  <data key="d1">Suicide</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The killing of oneself, treated as contrary to self-love, the community, and God.</data>
  <data key="d5"></data>
</node>
<node id="concept.tale_bearing">
  <data key="d0">concept.tale_bearing</data>
  <data key="d1">Tale-Bearing</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Secret evil-speaking ordered chiefly to the breaking of friendship.</data>
  <data key="d5"></data>
</node>
<node id="concept.theft">
  <data key="d0">concept.theft</data>
  <data key="d1">Theft</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The secret taking of another's property against the order of justice.</data>
  <data key="d5"></data>
</node>
<node id="concept.transgression">
  <data key="d0">concept.transgression</data>
  <data key="d1">Transgression</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Sin by stepping beyond the affirmative or negative rule of a precept.</data>
  <data key="d5"></data>
</node>
<node id="concept.truth_in_legal_proceedings">
  <data key="d0">concept.truth_in_legal_proceedings</data>
  <data key="d1">Truth in Legal Proceedings</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The truthful order on which just accusation, testimony, and defense depend.</data>
  <data key="d5"></data>
</node>
<node id="concept.unjust_appeal">
  <data key="d0">concept.unjust_appeal</data>
  <data key="d1">Unjust Appeal</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">An appeal made not from injustice suffered, but to delay or evade a just sentence.</data>
  <data key="d5"></data>
</node>
<node id="concept.unjust_detention">
  <data key="d0">concept.unjust_detention</data>
  <data key="d1">Unjust Detention</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The unjust restraint of a person's freedom of movement.</data>
  <data key="d5"></data>
</node>
<node id="concept.unjust_judgment">
  <data key="d0">concept.unjust_judgment</data>
  <data key="d1">Unjust Judgment</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A perversion of judgment that fails the order of justice.</data>
  <data key="d5"></data>
</node>
<node id="concept.unjust_killing">
  <data key="d0">concept.unjust_killing</data>
  <data key="d1">Unjust Killing</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The unjust taking of innocent human life.</data>
  <data key="d5"></data>
</node>
<node id="concept.usurped_judgment">
  <data key="d0">concept.usurped_judgment</data>
  <data key="d1">Usurped Judgment</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Judgment wrongfully assumed by one who lacks the proper authority.</data>
  <data key="d5"></data>
</node>
<node id="concept.usury">
  <data key="d0">concept.usury</data>
  <data key="d1">Usury</data>
  <data key="d2">wrong_act</data>
