  <data key="d5"></data>
</node>
<node id="concept.friendship_with_god">
  <data key="d0">concept.friendship_with_god</data>
  <data key="d1">Friendship with God</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
