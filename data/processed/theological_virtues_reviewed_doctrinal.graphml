  <data key="d5"></data>
</node>
<node id="concept.faith">
  <data key="d0">concept.faith</data>
  <data key="d1">Faith</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Theological virtue assenting to divine truth on God's authority.</data>
  <data key="d5"></data>
</node>
