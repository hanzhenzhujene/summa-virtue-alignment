  <data key="d0">concept.ecclesial_unity</data>
  <data key="d1">Ecclesial Unity</data>
  <data key="d2">doctrine</data>
  <data key="d3">seed</data>
  <data key="d4">The unity of the Church and its members described as an effect of charity.</data>
  <data key="d5"></data>
</node>
<node id="concept.envy">
  <data key="d0">concept.envy</data>
  <data key="d1">Envy</data>
  <data key="d2">sin_type</data>
  <data key="d3">seed</data>
  <data key="d4">Grief over a neighbor's good in a way contrary to charity.</data>
  <data key="d5"></data>
</node>
<node id="concept.eternal_life">
  <data key="d0">concept.eternal_life</data>
  <data key="d1">Eternal Life</data>
  <data key="d2">end</data>
  <data key="d3">reviewed_seed</data>
