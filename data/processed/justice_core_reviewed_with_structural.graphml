<edge source="concept.injustice" target="concept.charity" id="edge.concept.injustice.contrary_to.concept.charity">
  <data key="d6">edge.concept.injustice.contrary_to.concept.charity</data>
  <data key="d7">concept.injustice</data>
  <data key="d8">Injustice</data>
  <data key="d9">vice</data>
