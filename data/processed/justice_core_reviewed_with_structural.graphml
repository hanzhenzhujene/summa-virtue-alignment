  <data key="d16">explicit_textual</data>
  <data key="d17">erson , or when this is decreed by the prince who is placed over the people, and acts in its stead, and this is called "positive right."</data>
  <data key="d18">reviewed_structural_editorial</data>
</edge>
<edge source="st.ii-ii.q057.a002" target="concept.right" id="edge.st.ii-ii.q057.a002.treated_in.concept.right">
