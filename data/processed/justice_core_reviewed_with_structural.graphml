  <data key="d10">treated_in</data>
  <data key="d11">concept.life</data>
  <data key="d12">Life</data>
  <data key="d13">domain</data>
  <data key="d14">ann.st-ii-ii-q064-a001-treated-in-concept-life-st-ii-ii-q064-a001-resp</data>
  <data key="d15">st.ii-ii.q064.a001.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">man there is first a living thing, then an animal, and lastly a man, so too things, like the plants, which merely have life, are all alike for animals, and all animals are for man . Wherefore it is not unlawful if man use plants for the good of animals, and animals for the good of m</data>
  <data key="d18">reviewed_structural_editorial</data>
</edge>
<edge source="st.ii-ii.q064.a002" target="concept.life" id="edge.st.ii-ii.q064.a002.treated_in.concept.life">
