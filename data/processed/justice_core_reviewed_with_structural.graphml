  <data key="d10">treated_in</data>
  <data key="d11">concept.distributive_justice</data>
  <data key="d12">Distributive Justice</data>
  <data key="d13">virtue</data>
  <data key="d14">ann.st-ii-ii-q063-a001-treated-in-concept-distributive-justice-st-ii-ii-q063-a001-resp</data>
  <data key="d15">st.ii-ii.q063.a001.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">Respect of persons is opposed to distributive justice . For the equality of distributive justice consists in allotting various things to various persons in proportion to their personal dignity. Accordingly, if one</data>
  <data key="d18">reviewed_structural_editorial</data>
</edge>
