  <data key="d7">st.ii-ii.q071.a002</data>
  <data key="d8">II-II q.71 a.2 — Should certain persons be prohibited from exercising the office of advocate?</data>
  <data key="d9">article</data>
  <data key="d10">treated_in</data>
  <data key="d11">concept.advocate_role</data>
  <data key="d12">Advocate</data>
  <data key="d13">role</data>
  <data key="d14">ann.st-ii-ii-q071-a002-treated-in-concept-advocate-role-st-ii-ii-q071-a002-resp</data>
  <data key="d15">st.ii-ii.q071.a002.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">arred altogether, since necessity may do away with its unbecomingness. Accordingly some are debarred from the office of advocate because it is impossible to them through lack of sense—either interior, as in the case of madmen and minors—or exterior, as in the case of the deaf and dumb. F</data>
  <data key="d18">reviewed_structural_editorial</data>
</edge>
<edge source="st.ii-ii.q071.a003" target="concept.advocate_role" id="edge.st.ii-ii.q071.a003.treated_in.concept.advocate_role">
