  <data key="d7">st.ii-ii.q057.a003</data>
  <data key="d8">II-II q.57 a.3 — Is the right of nations the same as natural right?</data>
  <data key="d9">article</data>
  <data key="d10">treated_in</data>
  <data key="d11">concept.right</data>
  <data key="d12">Right</data>
