</edge>
<edge source="st.ii-ii.q063" target="st.ii-ii.q063.a001" id="structural.st.ii-ii.q063.contains.st.ii-ii.q063.a001">
  <data key="d6">structural.st.ii-ii.q063.contains.st.ii-ii.q063.a001</data>
  <data key="d7">st.ii-ii.q063</data>
  <data key="d8">II-II q.63 — Respect of persons</data>
