  <data key="d7">st.ii-ii.q066.a002</data>
  <data key="d8">II-II q.66 a.2 — Is it lawful for a man to possess something as his own?</data>
  <data key="d9">article</data>
  <data key="d10">treated_in</data>
  <data key="d11">concept.property</data>
  <data key="d12">Property</data>
  <data key="d13">domain</data>
  <data key="d14">ann.st-ii-ii-q066-a002-treated-in-concept-property-st-ii-ii-q066-a002-resp</data>
  <data key="d15">st.ii-ii.q066.a002.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">t of exterior things. One is the power to procure and dispense them, and in this regard it is lawful for man to possess property. Moreover this is necessary to human life for three reasons. First because every man is more careful to procure what is for himself alone than that which is co</data>
  <data key="d18">reviewed_structural_editorial</data>
</edge>
<edge source="st.ii-ii.q066.a003" target="concept.property" id="edge.st.ii-ii.q066.a003.treated_in.concept.property">
