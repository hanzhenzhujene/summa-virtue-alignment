  <data key="d7">st.ii-ii.q066.a003</data>
  <data key="d8">II-II q.66 a.3 — Is theft the secret taking of another's property?</data>
  <data key="d9">article</data>
  <data key="d10">treated_in</data>
  <data key="d11">concept.property</data>
