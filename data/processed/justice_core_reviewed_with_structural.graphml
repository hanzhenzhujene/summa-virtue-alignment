  <data key="d15">st.ii-ii.q066.a004.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">Theft and robbery are vices contrary to justice , in as much as one man does another an injustice . Now "no man suffers an injustice willingly," as stated in Ethic. v, 9. Wheref</data>
  <data key="d18">reviewed_structural_editorial</data>
</edge>
<edge source="st.ii-ii.q066.a005" target="concept.property" id="edge.st.ii-ii.q066.a005.treated_in.concept.property">
  <data key="d6">edge.st.ii-ii.q066.a005.treated_in.concept.property</data>
  <data key="d7">st.ii-ii.q066.a005</data>
  <data key="d8">II-II q.66 a.5 — Is every theft a sin?</data>
  <data key="d9">article</data>
  <data key="d10">treated_in</data>
  <data key="d11">concept.property</data>
  <data key="d12">Property</data>
  <data key="d13">domain</data>
