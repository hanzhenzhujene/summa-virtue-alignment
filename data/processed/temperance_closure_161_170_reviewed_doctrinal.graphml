<graph edgedefault="directed"><node id="concept.adams_first_sin">
  <data key="d0">concept.adams_first_sin</data>
  <data key="d1">Adam's First Sin</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The tract-local doctrinal case of the first sin of the first man, treated under pride without collapsing into the generic vice node.</data>
  <data key="d5"></data>
</node>
<node id="concept.adultery_lust">
  <data key="d0">concept.adultery_lust</data>
  <data key="d1">Adultery</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Adultery as treated within the species of lust in q.154.</data>
  <data key="d5"></data>
</node>
<node id="concept.anger_vice">
  <data key="d0">concept.anger_vice</data>
  <data key="d1">Anger (Vice-Level)</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Anger insofar as it becomes sinful by setting aside the order of reason.</data>
  <data key="d5"></data>
</node>
<node id="concept.bodily_defects_first_sin">
  <data key="d0">concept.bodily_defects_first_sin</data>
  <data key="d1">Bodily Defects (Punishments of the First Sin)</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Bodily corruption, sickness, and defect as punishments following the loss of original integrity.</data>
  <data key="d5"></data>
</node>
<node id="concept.boorishness">
  <data key="d0">concept.boorishness</data>
  <data key="d1">Boorishness / Rudeness</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The vice of deficient playfulness that makes a person burdensome to others in ordinary intercourse.</data>
  <data key="d5"></data>
</node>
<node id="concept.curiosity">
  <data key="d0">concept.curiosity</data>
  <data key="d1">Curiosity</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Disordered pursuit of knowledge or inquiry, opposed to studiousness in this temperance tract.</data>
  <data key="d5"></data>
</node>
<node id="concept.death_first_sin">
  <data key="d0">concept.death_first_sin</data>
  <data key="d1">Death (Punishment of the First Sin)</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Death as the common punishment flowing from the first sin.</data>
  <data key="d5"></data>
</node>
<node id="concept.decalogue">
  <data key="d0">concept.decalogue</data>
  <data key="d1">Decalogue</data>
  <data key="d2">precept</data>
  <data key="d3">seed</data>
  <data key="d4">The principal set of precepts delivered in the Old Law.</data>
  <data key="d5"></data>
</node>
<node id="concept.disordered_inquiry">
  <data key="d0">concept.disordered_inquiry</data>
  <data key="d1">Disordered Inquiry</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The inordinate study or pursuit of knowledge treated under curiosity.</data>
  <data key="d5"></data>
</node>
<node id="concept.divine_likeness">
  <data key="d0">concept.divine_likeness</data>
  <data key="d1">Divine Likeness</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The likeness to God that the first man inordinately coveted beyond due measure.</data>
  <data key="d5"></data>
</node>
<node id="concept.eutrapelia">
  <data key="d0">concept.eutrapelia</data>
  <data key="d1">Wittiness / Eutrapelia</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue governing games and playful actions according to reason as part of external modesty.</data>
  <data key="d5"></data>
</node>
<node id="concept.excessive_adornment">
  <data key="d0">concept.excessive_adornment</data>
  <data key="d1">Excessive Adornment</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Immoderate attention to outward apparel seeking glory, pleasure, or excessive solicitude.</data>
  <data key="d5"></data>
</node>
<node id="concept.excessive_play">
  <data key="d0">concept.excessive_play</data>
  <data key="d1">Excessive Play</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The vice of going beyond reason in playful words or deeds.</data>
  <data key="d5"></data>
</node>
<node id="concept.external_behavior_modesty">
  <data key="d0">concept.external_behavior_modesty</data>
  <data key="d1">Modesty in Outward Movements</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The tract-local species of modesty governing outward bodily movements and serious external behavior.</data>
  <data key="d5"></data>
</node>
<node id="concept.first_parents_temptation">
  <data key="d0">concept.first_parents_temptation</data>
  <data key="d1">Temptation of the First Parents</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The tract-local temptation case leading toward Adam's first sin by intellective and sensitive incentives.</data>
  <data key="d5"></data>
</node>
<node id="concept.god">
  <data key="d0">concept.god</data>
  <data key="d1">God</data>
  <data key="d2">object</data>
  <data key="d3">seed</data>
  <data key="d4">God as the object or term of theological virtue and charity.</data>
  <data key="d5"></data>
</node>
<node id="concept.humility">
  <data key="d0">concept.humility</data>
  <data key="d1">Humility</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue that restrains a person from aiming above due measure and submits the spirit under God.</data>
  <data key="d5"></data>
</node>
<node id="concept.knowledge">
  <data key="d0">concept.knowledge</data>
  <data key="d1">Knowledge</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Cognitive grasp used here for prophecy and other intellectual acts.</data>
  <data key="d5"></data>
</node>
<node id="concept.knowledge_good_and_evil">
  <data key="d0">concept.knowledge_good_and_evil</data>
  <data key="d1">Knowledge of Good and Evil</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The knowledge-related likeness to God especially coveted in the first sin narrative as interpreted in this tract.</data>
  <data key="d5"></data>
</node>
<node id="concept.loss_of_paradise">
  <data key="d0">concept.loss_of_paradise</data>
  <data key="d1">Loss of Paradise</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The deprivation of the place and state befitting original innocence after the first sin.</data>
  <data key="d5"></data>
</node>
<node id="concept.meekness">
  <data key="d0">concept.meekness</data>
  <data key="d1">Meekness</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue moderating the passion of anger under reason.</data>
  <data key="d5"></data>
</node>
<node id="concept.modesty_general">
  <data key="d0">concept.modesty_general</data>
  <data key="d1">Modesty (General)</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The annexed virtue moderating lesser matters where restraint is easier than in temperance proper.</data>
  <data key="d5"></data>
</node>
<node id="concept.ordered_inquiry">
  <data key="d0">concept.ordered_inquiry</data>
  <data key="d1">Ordered Inquiry</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The rightly ordered pursuit of knowledge under reason and due end.</data>
  <data key="d5"></data>
</node>
<node id="concept.outward_apparel">
  <data key="d0">concept.outward_apparel</data>
  <data key="d1">Outward Apparel</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Dress, ornament, and outward attire as matter moderated under exterior modesty.</data>
  <data key="d5"></data>
</node>
<node id="concept.outward_attire_modesty">
  <data key="d0">concept.outward_attire_modesty</data>
  <data key="d1">Modesty in Outward Apparel</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The tract-local exterior-modesty species governing attire, ornament, and dress under reason and fitting custom.</data>
  <data key="d5"></data>
</node>
<node id="concept.outward_behavior">
  <data key="d0">concept.outward_behavior</data>
  <data key="d1">Outward Behavior</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The field of bodily bearing, gesture, and exterior deportment moderated under this part of modesty.</data>
  <data key="d5"></data>
</node>
<node id="concept.own_excellence">
  <data key="d0">concept.own_excellence</data>
  <data key="d1">One's Own Excellence</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The difficult good or excellence inordinately desired by pride.</data>
  <data key="d5"></data>
</node>
<node id="concept.playful_actions">
  <data key="d0">concept.playful_actions</data>
  <data key="d1">Playful Actions</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Words or deeds whose immediate end is delight and rest of soul in play.</data>
  <data key="d5"></data>
</node>
<node id="concept.precepts_of_temperance">
  <data key="d0">concept.precepts_of_temperance</data>
  <data key="d1">Precepts of Temperance</data>
  <data key="d2">precept</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The tract-local synthesis of precepts directly bearing on temperance itself.</data>
  <data key="d5"></data>
</node>
<node id="concept.precepts_of_temperance_parts">
  <data key="d0">concept.precepts_of_temperance_parts</data>
  <data key="d1">Precepts of the Parts of Temperance</data>
  <data key="d2">precept</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The tract-local synthesis of precepts touching the annexed virtues and opposed vices of temperance's parts.</data>
  <data key="d5"></data>
</node>
<node id="concept.pride">
  <data key="d0">concept.pride</data>
  <data key="d1">Pride</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Inordinate self-exaltation by which a person aims above what is proportionate under the divine rule.</data>
  <data key="d5"></data>
</node>
<node id="concept.rebellion_of_carnal_appetite">
  <data key="d0">concept.rebellion_of_carnal_appetite</data>
  <data key="d1">Rebellion of the Carnal Appetite</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The disorder whereby the lower appetite rebels against reason as punishment of the first sin.</data>
  <data key="d5"></data>
</node>
<node id="concept.studiousness">
  <data key="d0">concept.studiousness</data>
  <data key="d1">Studiousness</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue moderating the soul's natural desire to know.</data>
  <data key="d5"></data>
</node>
<node id="concept.temperance">
  <data key="d0">concept.temperance</data>
  <data key="d1">Temperance</data>
  <data key="d2">virtue</data>
  <data key="d3">seed</data>
  <data key="d4">The cardinal virtue moderating attractions of pleasure.</data>
  <data key="d5"></data>
</node>
<node id="concept.truth_about_self">
  <data key="d0">concept.truth_about_self</data>
  <data key="d1">Truth About Oneself</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The rule by which humility knows and acknowledges one's proportion and deficiency.</data>
  <data key="d5"></data>
</node>
<node id="concept.vice">
  <data key="d0">concept.vice</data>
  <data key="d1">Vice</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Vice considered as privative disorder contrary to virtue.</data>
  <data key="d5"></data>
</node>
<node id="concept.virtue">
  <data key="d0">concept.virtue</data>
  <data key="d1">Virtue</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Generic virtue as good operative perfection.</data>
  <data key="d5">Do not collapse generic virtue into a specific virtue without explicit passage support.</data>
</node>
