  <data key="d15">st.ii-ii.q163.a001.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">od above his measure: and this pertains to pride . Therefore it is evident that man's first sin was pride .</data>
  <data key="d18">reviewed_doctrinal</data>
  <data key="d19">adams_first_sin</data>
  <data key="d20">adam_case | adams_first_sin</data>
