<edge source="st.ii-ii.q118" target="st.ii-ii.q118.a004" id="structural.st.ii-ii.q118.contains.st.ii-ii.q118.a004">
  <data key="d6">structural.st.ii-ii.q118.contains.st.ii-ii.q118.a004</data>
  <data key="d7">st.ii-ii.q118</data>
  <data key="d8">II-II q.118 — The vices opposed to liberality, and in the first place, of covetousness</data>
  <data key="d9">question</data>
  <data key="d10">contains_article</data>
  <data key="d11">st.ii-ii.q118.a004</data>
  <data key="d12">II-II q.118 a.4 — Is it a mortal sin?</data>
