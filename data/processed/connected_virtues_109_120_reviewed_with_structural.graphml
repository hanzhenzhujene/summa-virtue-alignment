<graph edgedefault="directed"><node id="concept.boasting">
  <data key="d0">concept.boasting</data>
  <data key="d1">Boasting</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">False self-exaltation by speaking above what one truly is.</data>
  <data key="d5"></data>
</node>
<node id="concept.common_good">
  <data key="d0">concept.common_good</data>
  <data key="d1">Common Good</data>
  <data key="d2">end</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Good of the whole community rather than of a private individual alone.</data>
  <data key="d5"></data>
</node>
<node id="concept.covetousness">
  <data key="d0">concept.covetousness</data>
  <data key="d1">Covetousness</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Immoderate love of having possessions or riches.</data>
  <data key="d5"></data>
</node>
<node id="concept.dissimulation">
  <data key="d0">concept.dissimulation</data>
  <data key="d1">Dissimulation</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A lie told by outward deeds or signs through showing oneself otherwise than one is.</data>
  <data key="d5"></data>
</node>
<node id="concept.epikeia">
  <data key="d0">concept.epikeia</data>
  <data key="d1">Epikeia / Equity</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue correcting merely literal legal application in order to preserve justice and the common good in singular cases.</data>
  <data key="d5"></data>
</node>
<node id="concept.external_goods">
  <data key="d0">concept.external_goods</data>
  <data key="d1">External Goods</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The domain of money and possessions that can be used, given, acquired, or retained.</data>
  <data key="d5"></data>
</node>
<node id="concept.flattery">
  <data key="d0">concept.flattery</data>
  <data key="d1">Flattery</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Excessive pleasing of others in ordinary interaction beyond the mode of virtue.</data>
  <data key="d5"></data>
</node>
<node id="concept.friendliness_affability">
  <data key="d0">concept.friendliness_affability</data>
  <data key="d1">Friendliness / Affability</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue maintaining becoming conduct in ordinary relations by pleasing others appropriately.</data>
  <data key="d5"></data>
</node>
<node id="concept.giving">
  <data key="d0">concept.giving</data>
  <data key="d1">Giving</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The act of parting with money or possessions to another.</data>
  <data key="d5"></data>
</node>
<node id="concept.hypocrisy">
  <data key="d0">concept.hypocrisy</data>
  <data key="d1">Hypocrisy</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A species of dissimulation in which a person simulates the character of a just man without being such in reality.</data>
  <data key="d5"></data>
</node>
<node id="concept.intent_of_law">
  <data key="d0">concept.intent_of_law</data>
  <data key="d1">Intent of Law</data>
  <data key="d2">doctrine</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">What the law seeks in view in ordering cases toward justice and the common good.</data>
  <data key="d5"></data>
</node>
<node id="concept.irony">
  <data key="d0">concept.irony</data>
  <data key="d1">Irony</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">False self-belittling by denying or diminishing goods one truly has.</data>
  <data key="d5">This is the tract's vice of understatement, not modern rhetorical irony.</data>
</node>
<node id="concept.justice">
  <data key="d0">concept.justice</data>
  <data key="d1">Justice</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Moral virtue rendering acts and agents right in relation to another.</data>
  <data key="d5"></data>
</node>
<node id="concept.law">
  <data key="d0">concept.law</data>
  <data key="d1">Law</data>
  <data key="d2">law</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Law as ordinance of reason for the common good.</data>
  <data key="d5">Generic law is kept distinct from named law-types unless the text is explicit.</data>
</node>
<node id="concept.legal_letter">
  <data key="d0">concept.legal_letter</data>
  <data key="d1">Letter of the Law</data>
  <data key="d2">law</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The merely literal application of a law in a case where following the words alone would frustrate justice.</data>
  <data key="d5"></data>
</node>
<node id="concept.liberality">
  <data key="d0">concept.liberality</data>
  <data key="d1">Liberality</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue moderating the use of money or external goods, especially in giving.</data>
  <data key="d5"></data>
</node>
<node id="concept.lying">
  <data key="d0">concept.lying</data>
  <data key="d1">Lying</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The sinful false signification of what is in one's mind.</data>
  <data key="d5"></data>
</node>
<node id="concept.prodigality">
  <data key="d0">concept.prodigality</data>
  <data key="d1">Prodigality</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Excessive giving and deficient retaining or acquiring with respect to riches.</data>
  <data key="d5"></data>
</node>
<node id="concept.quarreling">
  <data key="d0">concept.quarreling</data>
  <data key="d1">Quarreling</data>
  <data key="d2">wrong_act</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Contradictory disagreeableness in ordinary social interaction, opposed to affability.</data>
  <data key="d5"></data>
</node>
<node id="concept.retaining">
  <data key="d0">concept.retaining</data>
  <data key="d1">Retaining</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The act of keeping or holding possessions instead of parting with them.</data>
  <data key="d5"></data>
</node>
<node id="concept.self_presentation">
  <data key="d0">concept.self_presentation</data>
  <data key="d1">Self-Presentation</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The domain of manifesting oneself truthfully or falsely by words or deeds.</data>
  <data key="d5"></data>
</node>
<node id="concept.social_interaction">
  <data key="d0">concept.social_interaction</data>
  <data key="d1">Social Interaction</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The domain of ordinary human dealings in words and deeds among those with whom one dwells.</data>
  <data key="d5"></data>
</node>
<node id="concept.truth_self_presentation">
  <data key="d0">concept.truth_self_presentation</data>
  <data key="d1">Truth</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The annexed virtue by which a person manifests himself as he is in words and deeds.</data>
  <data key="d5">This tract-local truth is truthful self-manifestation, not First Truth or theological truth in the faith tract.</data>
</node>
<node id="st.ii-ii.q109">
