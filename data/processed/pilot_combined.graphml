  <data key="d12">Object of Faith</data>
  <data key="d13">doctrine</data>
  <data key="d14">structural</data>
  <data key="d15">ann.st-ii-ii-q001-a003-treated-in-concept-object-of-faith-st-ii-ii-q001-a003-resp</data>
  <data key="d16">st.ii-ii.q001.a003.resp</data>
