  <data key="d20"></data>
</edge>
<edge source="st.ii-ii.q001.a003" target="concept.faith" id="edge.st.ii-ii.q001.a003.treated_in.concept.faith">
  <data key="d6">edge.st.ii-ii.q001.a003.treated_in.concept.faith</data>
  <data key="d7">st.ii-ii.q001.a003</data>
  <data key="d8">II-II q.1 a.3 — Can anything false come under faith?</data>
  <data key="d9">article</data>
  <data key="d10">treated_in</data>
  <data key="d11">concept.faith</data>
  <data key="d12">Faith</data>
  <data key="d13">virtue</data>
  <data key="d14">structural</data>
  <data key="d15">ann.st-ii-ii-q001-a003-treated-in-concept-faith-st-ii-ii-q001-a003-resp</data>
  <data key="d16">st.ii-ii.q001.a003.resp</data>
  <data key="d17">explicit_textual</data>
  <data key="d18">Now it has been stated ( Article 1 ) that the formal aspect of the object of faith is the First Truth</data>
  <data key="d19"></data>
  <data key="d20"></data>
</edge>
<edge source="st.ii-ii.q001.a003" target="concept.object_of_faith" id="edge.st.ii-ii.q001.a003.treated_in.concept.object_of_faith">
