  <data key="d18">Man must, of necessity , desire all, whatsoever he desires, for the last end</data>
  <data key="d19"></data>
  <data key="d20"></data>
</edge>
<edge source="st.i-ii.q001.a007" target="concept.end" id="edge.st.i-ii.q001.a007.treated_in.concept.end">
  <data key="d6">edge.st.i-ii.q001.a007.treated_in.concept.end</data>
  <data key="d7">st.i-ii.q001.a007</data>
  <data key="d8">I-II q.1 a.7 — Do all men have the same last end?</data>
  <data key="d9">article</data>
  <data key="d10">treated_in</data>
  <data key="d11">concept.end</data>
  <data key="d12">End</data>
  <data key="d13">end</data>
  <data key="d14">structural</data>
  <data key="d15">ann.st-i-ii-q001-a007-treated-in-concept-end-st-i-ii-q001-a007-resp</data>
  <data key="d16">st.i-ii.q001.a007.resp</data>
  <data key="d17">explicit_textual</data>
  <data key="d18">We can speak of the last end in two ways: first, considering only the aspect of last end</data>
  <data key="d19"></data>
  <data key="d20"></data>
</edge>
<edge source="st.i-ii.q001.a007" target="concept.ultimate_end" id="edge.st.i-ii.q001.a007.treated_in.concept.ultimate_end">
