  <data key="d6">edge.st.ii-ii.q137.a003.treated_in.concept.perseverance_virtue</data>
  <data key="d7">st.ii-ii.q137.a003</data>
  <data key="d8">II-II q.137 a.3 — Its relation to constancy</data>
