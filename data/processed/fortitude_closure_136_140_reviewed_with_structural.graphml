  <data key="d10">treated_in</data>
  <data key="d11">concept.grace</data>
  <data key="d12">Grace</data>
  <data key="d13">grace</data>
  <data key="d14">ann.st-ii-ii-q136-a003-treated-in-concept-grace-st-ii-ii-q136-a003-resp</data>
  <data key="d15">st.ii-ii.q136.a003.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">s poured forth in our hearts by the Holy Ghost Who is given to us." Therefore it is clearly impossible to have patience without the help of grace .</data>
  <data key="d18">reviewed_structural_editorial</data>
  <data key="d19">patience</data>
</edge>
