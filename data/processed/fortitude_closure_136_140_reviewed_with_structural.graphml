  <data key="d16">strong_textual_inference</data>
  <data key="d17">As stated above ( II-II:3:2 ), although affirmative precepts are always binding, they are not binding for always, but according to place and time. Wherefore just as the affirmative precepts about the other virtues are to be understood as to</data>
  <data key="d18">reviewed_doctrinal</data>
  <data key="d19">precept</data>
</edge>
<edge source="concept.precepts_of_fortitude_parts" target="concept.fortitude" id="edge.concept.precepts_of_fortitude_parts.precept_of.concept.fortitude">
  <data key="d6">edge.concept.precepts_of_fortitude_parts.precept_of.concept.fortitude</data>
  <data key="d7">concept.precepts_of_fortitude_parts</data>
  <data key="d8">Precepts of Patience and Perseverance</data>
  <data key="d9">precept</data>
  <data key="d10">precept_of</data>
