<graph edgedefault="directed"><node id="concept.caution">
  <data key="d0">concept.caution</data>
  <data key="d1">Caution</data>
  <data key="d2">prudence_part</data>
  <data key="d3">approved</data>
  <data key="d4">integral</data>
  <data key="d5">Integral part of prudence avoiding evils mixed with apparent goods.</data>
  <data key="d6"></data>
</node>
<node id="concept.circumspection">
  <data key="d0">concept.circumspection</data>
  <data key="d1">Circumspection</data>
  <data key="d2">prudence_part</data>
  <data key="d3">approved</data>
  <data key="d4">integral</data>
  <data key="d5">Integral part of prudence attending to relevant circumstances.</data>
  <data key="d6"></data>
</node>
<node id="concept.command">
  <data key="d0">concept.command</data>
  <data key="d1">Command</data>
  <data key="d2">act</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">The principal act of prudence in commanding action.</data>
  <data key="d6"></data>
</node>
<node id="concept.common_good">
  <data key="d0">concept.common_good</data>
  <data key="d1">Common Good</data>
  <data key="d2">end</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">The communal end to which public prudence is ordered.</data>
  <data key="d6"></data>
</node>
<node id="concept.counsel_gift">
  <data key="d0">concept.counsel_gift</data>
  <data key="d1">Gift of Counsel</data>
  <data key="d2">gift_holy_spirit</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">The corresponding gift of the Holy Ghost perfecting prudence.</data>
  <data key="d6">Keep distinct from counsel as an act of deliberation.</data>
</node>
<node id="concept.covetousness">
  <data key="d0">concept.covetousness</data>
  <data key="d1">Covetousness</data>
  <data key="d2">vice</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">Vice named as the chief origin of counterfeit prudence-like forms in Q55 a8.</data>
  <data key="d6"></data>
</node>
<node id="concept.craftiness">
  <data key="d0">concept.craftiness</data>
  <data key="d1">Craftiness</data>
  <data key="d2">vice</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">Counterfeit prudence using fictitious or counterfeit means.</data>
  <data key="d6"></data>
</node>
<node id="concept.docility">
  <data key="d0">concept.docility</data>
  <data key="d1">Docility</data>
  <data key="d2">prudence_part</data>
  <data key="d3">approved</data>
  <data key="d4">integral</data>
  <data key="d5">Integral part of prudence disposing a person to learn from others.</data>
  <data key="d6"></data>
</node>
<node id="concept.domestic_prudence">
  <data key="d0">concept.domestic_prudence</data>
  <data key="d1">Domestic Prudence</data>
  <data key="d2">prudence_part</data>
  <data key="d3">approved</data>
  <data key="d4">subjective</data>
  <data key="d5">Subjective part of prudence governing the household.</data>
  <data key="d6">The source title uses 'domestic economy'; the normalized concept remains Domestic Prudence.</data>
</node>
<node id="concept.euboulia">
  <data key="d0">concept.euboulia</data>
  <data key="d1">Euboulia</data>
  <data key="d2">prudence_part</data>
  <data key="d3">approved</data>
  <data key="d4">potential</data>
  <data key="d5">Potential part of prudence concerned with good counsel.</data>
  <data key="d6">Keep the transliterated term because the tract names it directly.</data>
</node>
<node id="concept.false_prudence">
  <data key="d0">concept.false_prudence</data>
  <data key="d1">False Prudence</data>
  <data key="d2">vice</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">A prudence-like likeness directed to an apparent good rather than true good.</data>
  <data key="d6">Keep distinct from craftiness and prudence of the flesh.</data>
</node>
<node id="concept.foresight">
  <data key="d0">concept.foresight</data>
  <data key="d1">Foresight</data>
  <data key="d2">prudence_part</data>
  <data key="d3">approved</data>
  <data key="d4">integral</data>
  <data key="d5">Integral part of prudence ordering means fittingly to the end.</data>
  <data key="d6"></data>
</node>
<node id="concept.fraud">
  <data key="d0">concept.fraud</data>
  <data key="d1">Fraud</data>
  <data key="d2">vice</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">Execution of craftiness more properly by deeds.</data>
  <data key="d6"></data>
</node>
<node id="concept.future_solicitude">
  <data key="d0">concept.future_solicitude</data>
  <data key="d1">Solicitude about the Future</data>
  <data key="d2">defect</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">Needlessly forestalling solicitude proper to a future time.</data>
  <data key="d6">Keep distinct from lawful prudential foresight.</data>
</node>
<node id="concept.gnome">
  <data key="d0">concept.gnome</data>
  <data key="d1">Gnome</data>
  <data key="d2">prudence_part</data>
  <data key="d3">approved</data>
  <data key="d4">potential</data>
  <data key="d5">Potential part of prudence judging according to higher principles in exceptional cases.</data>
  <data key="d6">Keep separate from synesis and from prudence generally.</data>
</node>
<node id="concept.guile">
  <data key="d0">concept.guile</data>
  <data key="d1">Guile</data>
  <data key="d2">vice</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">Execution of craftiness in words or deeds.</data>
  <data key="d6">Keep distinct from fraud, which is more properly by deeds.</data>
</node>
<node id="concept.imprudence">
  <data key="d0">concept.imprudence</data>
  <data key="d1">Imprudence</data>
  <data key="d2">vice</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">Vice opposed to prudence through lack or contrary movement of reason.</data>
  <data key="d6"></data>
</node>
<node id="concept.inconstancy">
  <data key="d0">concept.inconstancy</data>
  <data key="d1">Inconstancy</data>
  <data key="d2">defect</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">Defect of command withdrawing from a good purpose.</data>
  <data key="d6"></data>
</node>
<node id="concept.intelligence">
  <data key="d0">concept.intelligence</data>
  <data key="d1">Understanding or Intelligence</data>
  <data key="d2">prudence_part</data>
  <data key="d3">approved</data>
  <data key="d4">integral</data>
  <data key="d5">Integral part of prudence concerning right estimate of first practical principles.</data>
  <data key="d6">Do not collapse into the distinct gift of understanding from elsewhere in the corpus.</data>
</node>
<node id="concept.lust">
  <data key="d0">concept.lust</data>
  <data key="d1">Lust</data>
  <data key="d2">vice</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">Vice named as chief origin of defects of prudence in Q53 a6.</data>
  <data key="d6"></data>
</node>
<node id="concept.memory">
  <data key="d0">concept.memory</data>
  <data key="d1">Memory</data>
  <data key="d2">prudence_part</data>
  <data key="d3">approved</data>
  <data key="d4">integral</data>
  <data key="d5">Integral part of prudence concerning past experience.</data>
  <data key="d6"></data>
</node>
<node id="concept.mercy_beatitude">
  <data key="d0">concept.mercy_beatitude</data>
  <data key="d1">Beatitude of Mercy</data>
  <data key="d2">beatitude</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">The fifth beatitude associated here with the gift of counsel.</data>
  <data key="d6"></data>
</node>
<node id="concept.military_prudence">
  <data key="d0">concept.military_prudence</data>
  <data key="d1">Military Prudence</data>
  <data key="d2">prudence_part</data>
  <data key="d3">approved</data>
  <data key="d4">subjective</data>
  <data key="d5">Subjective part of prudence repelling hostile attacks for the common good.</data>
  <data key="d6"></data>
</node>
<node id="concept.negligence">
  <data key="d0">concept.negligence</data>
  <data key="d1">Negligence</data>
  <data key="d2">defect</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">Lack of due solicitude treated as pertaining to imprudence.</data>
  <data key="d6"></data>
</node>
<node id="concept.political_prudence">
  <data key="d0">concept.political_prudence</data>
  <data key="d1">Political Prudence</data>
  <data key="d2">prudence_part</data>
  <data key="d3">approved</data>
  <data key="d4">subjective</data>
  <data key="d5">Subjective part of prudence in subjects directing themselves in obedience.</data>
  <data key="d6">Article 50.2 uses the title 'political economy' in this edition; normalize the concept label as Political Prudence.</data>
</node>
<node id="concept.practical_reason">
  <data key="d0">concept.practical_reason</data>
  <data key="d1">Practical Reason</data>
  <data key="d2">faculty</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">Reason as ordered to action and counsel.</data>
  <data key="d6">Do not collapse into reason_faculty when the tract is specifically distinguishing practical from speculative reason.</data>
</node>
<node id="concept.precipitation">
  <data key="d0">concept.precipitation</data>
  <data key="d1">Precipitation or Temerity</data>
  <data key="d2">defect</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">Defect of counsel contained under imprudence.</data>
  <data key="d6"></data>
</node>
<node id="concept.prudence">
  <data key="d0">concept.prudence</data>
  <data key="d1">Prudence</data>
  <data key="d2">virtue</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">The cardinal virtue of right practical reason in things to be done.</data>
  <data key="d6"></data>
</node>
<node id="concept.prudence_of_flesh">
  <data key="d0">concept.prudence_of_flesh</data>
  <data key="d1">Prudence of the Flesh</data>
  <data key="d2">vice</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">Counterfeit prudence that treats bodily goods as the last end of life.</data>
  <data key="d6">Keep distinct from false prudence and from craftiness.</data>
</node>
<node id="concept.reason_faculty">
  <data key="d0">concept.reason_faculty</data>
  <data key="d1">Reason</data>
  <data key="d2">faculty</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">The rational cognitive faculty in which prudence is located.</data>
  <data key="d6">Keep distinct from Reasoning, the integral part of prudence in Q49 a5.</data>
</node>
<node id="concept.reasoning">
  <data key="d0">concept.reasoning</data>
  <data key="d1">Reasoning</data>
  <data key="d2">prudence_part</data>
  <data key="d3">approved</data>
  <data key="d4">integral</data>
  <data key="d5">Integral part of prudence in comparing one thing with another during counsel.</data>
  <data key="d6">Distinguish from reason_faculty, the cognitive power in which prudence resides.</data>
</node>
<node id="concept.regnative_prudence">
  <data key="d0">concept.regnative_prudence</data>
  <data key="d1">Regnative Prudence</data>
  <data key="d2">prudence_part</data>
  <data key="d3">approved</data>
  <data key="d4">subjective</data>
  <data key="d5">Subjective part of prudence belonging to rulers of a city or kingdom.</data>
  <data key="d6"></data>
</node>
<node id="concept.shrewdness">
  <data key="d0">concept.shrewdness</data>
  <data key="d1">Shrewdness</data>
  <data key="d2">prudence_part</data>
  <data key="d3">approved</data>
  <data key="d4">integral</data>
  <data key="d5">Integral part of prudence signifying apt discovery of the fitting course.</data>
  <data key="d6">The source sometimes glosses this through eustochia; keep the prudence-part label stable.</data>
</node>
<node id="concept.solicitude">
  <data key="d0">concept.solicitude</data>
  <data key="d1">Solicitude</data>
  <data key="d2">act</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">Prompt practical watchfulness treated as belonging to prudence.</data>
  <data key="d6">Keep separate from unlawful solicitude about temporal or future things in Q55.</data>
</node>
<node id="concept.synesis">
  <data key="d0">concept.synesis</data>
  <data key="d1">Synesis</data>
  <data key="d2">prudence_part</data>
  <data key="d3">approved</data>
  <data key="d4">potential</data>
  <data key="d5">Potential part of prudence concerned with good judgment under common law.</data>
  <data key="d6">Keep separate from gnome.</data>
</node>
<node id="concept.temporal_solicitude">
  <data key="d0">concept.temporal_solicitude</data>
  <data key="d1">Solicitude about Temporal Things</data>
  <data key="d2">defect</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">Unlawful solicitude seeking temporal things as end or with undue anxiety.</data>
  <data key="d6">Keep distinct from solicitude as a prudential act in Q47 a9.</data>
</node>
<node id="concept.thoughtlessness">
  <data key="d0">concept.thoughtlessness</data>
  <data key="d1">Thoughtlessness</data>
  <data key="d2">defect</data>
  <data key="d3">approved</data>
  <data key="d4"></data>
  <data key="d5">Defect of right judgment treated under imprudence.</data>
  <data key="d6"></data>
</node>
