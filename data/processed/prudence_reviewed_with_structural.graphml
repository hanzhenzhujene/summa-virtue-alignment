<edge source="concept.euboulia" target="concept.prudence" id="edge.concept.euboulia.potential_part_of.concept.prudence">
  <data key="d7">edge.concept.euboulia.potential_part_of.concept.prudence</data>
  <data key="d8">concept.euboulia</data>
  <data key="d9">Euboulia</data>
  <data key="d10">prudence_part</data>
