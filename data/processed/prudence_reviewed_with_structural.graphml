  <data key="d18">Inconstancy denotes withdrawal from a definite good purpose</data>
  <data key="d19">reviewed_doctrinal</data>
  <data key="d20"></data>
</edge>
<edge source="concept.intelligence" target="concept.prudence" id="edge.concept.intelligence.integral_part_of.concept.prudence">
  <data key="d7">edge.concept.intelligence.integral_part_of.concept.prudence</data>
  <data key="d8">concept.intelligence</data>
