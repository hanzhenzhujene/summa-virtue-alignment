  <data key="d12">st.ii-ii.q055.a004</data>
  <data key="d13">II-II q.55 a.4 — Guile</data>
  <data key="d14">article</data>
  <data key="d15">ann.st-ii-ii-q055-a004-resp-concept-guile-treated-in-st-ii-ii-q055-a004</data>
  <data key="d16">st.ii-ii.q055.a004.resp</data>
  <data key="d17">explicit_textual</data>
