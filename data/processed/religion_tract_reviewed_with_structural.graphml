</edge>
<edge source="st.ii-ii.q081" target="st.ii-ii.q081.a002" id="structural.st.ii-ii.q081.contains.st.ii-ii.q081.a002">
  <data key="d6">structural.st.ii-ii.q081.contains.st.ii-ii.q081.a002</data>
  <data key="d7">st.ii-ii.q081</data>
  <data key="d8">II-II q.81 — Religion</data>
  <data key="d9">question</data>
  <data key="d10">contains_article</data>
  <data key="d11">st.ii-ii.q081.a002</data>
  <data key="d12">II-II q.81 a.2 — Is religion a virtue?</data>
