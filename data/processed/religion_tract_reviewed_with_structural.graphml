  <data key="d16">explicit_textual</data>
  <data key="d17">to God . Therefore whatever pertains to irreverence for sacred things is an injury to God , and comes under the head of sacrilege .</data>
  <data key="d18">reviewed_structural_editorial</data>
</edge>
<edge source="st.ii-ii.q099.a002" target="concept.sacrilege" id="edge.st.ii-ii.q099.a002.treated_in.concept.sacrilege">
