  <data key="d10">contains_article</data>
  <data key="d11">st.ii-ii.q088.a012</data>
  <data key="d12">II-II q.88 a.12 — Is the authority of a superior required in a dispensation from a vow?</data>
  <data key="d13">article</data>
  <data key="d14"></data>
  <data key="d15">st.ii-ii.q088.a012.obj1</data>
  <data key="d16">structural_editorial</data>
  <data key="d17">It would seem that the authority of a prelate is not required for the commutation or dispensation of a vow . A person may enter religion without the authority of a superior prelate. Now by entering religion one is absolv</data>
  <data key="d18">structural</data>
</edge>
<edge source="st.ii-ii.q088.a001" target="concept.promise_to_god" id="edge.st.ii-ii.q088.a001.treated_in.concept.promise_to_god">
  <data key="d6">edge.st.ii-ii.q088.a001.treated_in.concept.promise_to_god</data>
