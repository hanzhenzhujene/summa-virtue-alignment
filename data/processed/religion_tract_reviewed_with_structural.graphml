  <data key="d10">treated_in</data>
  <data key="d11">concept.justice</data>
  <data key="d12">Justice</data>
  <data key="d13">virtue</data>
  <data key="d14">ann.st-ii-ii-q080-treated-in-concept-justice-st-ii-ii-q080-a001-resp</data>
  <data key="d15">st.ii-ii.q080.a001.resp</data>
  <data key="d16">structural_editorial</data>
  <data key="d17">al virtue ; and the second is that in some respect they fall short of the perfection of that virtue . Accordingly since justice is of one man to another as stated above ( II-II:58:2 ), all the virtues that are directed to another person may by reason of this common aspect be annexed to</data>
  <data key="d18">reviewed_structural_editorial</data>
</edge>
<edge source="st.ii-ii.q080" target="concept.religion" id="edge.st.ii-ii.q080.treated_in.concept.religion">
  <data key="d6">edge.st.ii-ii.q080.treated_in.concept.religion</data>
  <data key="d7">st.ii-ii.q080</data>
  <data key="d8">II-II q.80 — The potential parts of Justice</data>
  <data key="d9">question</data>
  <data key="d10">treated_in</data>
  <data key="d11">concept.religion</data>
  <data key="d12">Religion</data>
