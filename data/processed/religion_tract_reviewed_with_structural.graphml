  <data key="d15">st.ii-ii.q082.a003.resp</data>
  <data key="d16">structural_editorial</data>
  <data key="d17">The extrinsic and chief cause of devotion is God , of Whom Ambrose , commenting on Luke 9:55 , says that " God calls whom He deigns to call, and whom He wills He makes religious: the profane Samaritans, had He so willed,</data>
  <data key="d18">structural</data>
</edge>
<edge source="st.ii-ii.q082" target="st.ii-ii.q082.a004" id="structural.st.ii-ii.q082.contains.st.ii-ii.q082.a004">
