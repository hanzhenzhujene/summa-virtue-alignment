  <data key="d7">st.ii-ii.q086.a002</data>
  <data key="d8">II-II q.86 a.2 — To whom are oblations due?</data>
  <data key="d9">article</data>
  <data key="d10">treated_in</data>
  <data key="d11">concept.oblation</data>
