  <data key="d7">st.ii-ii.q080.a001</data>
  <data key="d8">II-II q.80 a.1 — What virtues are annexed to justice?</data>
  <data key="d9">article</data>
  <data key="d10">treated_in</data>
  <data key="d11">concept.justice</data>
