  <data key="d15">st.ii-ii.q100.a005.resp</data>
  <data key="d16">explicit_textual</data>
  <data key="d17">As stated above ( Article 2 ), the term "money" denotes "anything that can have a pecuniary value." Now it is evident that a man's service is directed to some kind of usefulness, which has a pecuniary value, wherefore servants are hired for a money wage. Th</data>
  <data key="d18">reviewed_doctrinal</data>
</edge>
<edge source="concept.simony" target="concept.spiritual_thing" id="edge.concept.simony.misuses_sacred_object.concept.spiritual_thing">
  <data key="d6">edge.concept.simony.misuses_sacred_object.concept.spiritual_thing</data>
  <data key="d7">concept.simony</data>
  <data key="d8">Simony</data>
  <data key="d9">sin_type</data>
