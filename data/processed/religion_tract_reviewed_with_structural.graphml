<graph edgedefault="directed"><node id="concept.adjuration">
  <data key="d0">concept.adjuration</data>
  <data key="d1">Adjuration</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A reverential calling on the divine name or a holy thing in order to obtain or command something.</data>
  <data key="d5"></data>
</node>
<node id="concept.adoration">
  <data key="d0">concept.adoration</data>
  <data key="d1">Adoration</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">An act of reverence offered to God, inwardly and outwardly.</data>
  <data key="d5"></data>
</node>
<node id="concept.astrological_divination">
  <data key="d0">concept.astrological_divination</data>
  <data key="d1">Astrological Divination</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Unlawful foreknowledge sought from the stars beyond what they can naturally signify.</data>
  <data key="d5"></data>
</node>
<node id="concept.augury">
  <data key="d0">concept.augury</data>
  <data key="d1">Augury</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Divination that reads birds, signs, or omens beyond the lawful order of nature or providence.</data>
  <data key="d5"></data>
</node>
<node id="concept.devotion">
  <data key="d0">concept.devotion</data>
  <data key="d1">Devotion</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The ready will to do what pertains to the worship and service of God.</data>
  <data key="d5"></data>
</node>
<node id="concept.divination">
  <data key="d0">concept.divination</data>
  <data key="d1">Divination</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Superstitious foretelling or seeking knowledge of the future from unlawful sources.</data>
  <data key="d5"></data>
</node>
<node id="concept.divination_by_demons">
  <data key="d0">concept.divination_by_demons</data>
  <data key="d1">Divination by Demons</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Divination that invokes demons explicitly for knowledge of the future.</data>
  <data key="d5"></data>
</node>
<node id="concept.divination_by_dreams">
  <data key="d0">concept.divination_by_dreams</data>
  <data key="d1">Divination by Dreams</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Superstitious use of dreams for unlawful foreknowledge when it exceeds natural or divine causes.</data>
  <data key="d5"></data>
</node>
<node id="concept.divine_name">
  <data key="d0">concept.divine_name</data>
  <data key="d1">Divine Name</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The holy name invoked in oath, adjuration, praise, and perjury.</data>
  <data key="d5"></data>
</node>
<node id="concept.divine_worship">
  <data key="d0">concept.divine_worship</data>
  <data key="d1">Divine Worship</data>
  <data key="d2">domain</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The domain of honor, reverence, and worship that is due to God alone.</data>
  <data key="d5"></data>
</node>
<node id="concept.first_fruits">
  <data key="d0">concept.first_fruits</data>
  <data key="d1">First-Fruits</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A special oblation offered to God in acknowledgment of divine favor.</data>
  <data key="d5"></data>
</node>
<node id="concept.fortune_telling_observance">
  <data key="d0">concept.fortune_telling_observance</data>
  <data key="d1">Fortune-Telling Observance</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A vain observance that treats arbitrary signs as indicators of future good or evil fortune.</data>
  <data key="d5"></data>
</node>
<node id="concept.healing_observance">
  <data key="d0">concept.healing_observance</data>
  <data key="d1">Superstitious Healing Observance</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">An unlawful observance that seeks bodily effects through signs rather than natural causes.</data>
  <data key="d5"></data>
</node>
<node id="concept.idolatry">
  <data key="d0">concept.idolatry</data>
  <data key="d1">Idolatry</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The superstitious giving of divine worship to a creature.</data>
  <data key="d5"></data>
</node>
<node id="concept.justice">
  <data key="d0">concept.justice</data>
  <data key="d1">Justice</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Moral virtue rendering acts and agents right in relation to another.</data>
  <data key="d5"></data>
</node>
<node id="concept.magical_observance">
  <data key="d0">concept.magical_observance</data>
  <data key="d1">Magical Observance</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A vain and unlawful observance that seeks knowledge through magical signs and words.</data>
  <data key="d5"></data>
</node>
<node id="concept.oath">
  <data key="d0">concept.oath</data>
  <data key="d1">Oath</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The calling of God to witness in confirmation of what one says.</data>
  <data key="d5"></data>
</node>
<node id="concept.oblation">
  <data key="d0">concept.oblation</data>
  <data key="d1">Oblation</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A thing offered for divine worship, whether or not it is destroyed as sacrifice.</data>
  <data key="d5"></data>
</node>
<node id="concept.perjury">
  <data key="d0">concept.perjury</data>
  <data key="d1">Perjury</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The perversity of swearing falsely and so irreverently calling God to witness.</data>
  <data key="d5"></data>
</node>
<node id="concept.praise_of_god">
  <data key="d0">concept.praise_of_god</data>
  <data key="d1">Praise of God</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Vocal praise directed to God in order to stir devotion and reverence.</data>
  <data key="d5"></data>
</node>
<node id="concept.prayer">
  <data key="d0">concept.prayer</data>
  <data key="d1">Prayer</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The act whereby a rational creature asks or petitions God.</data>
  <data key="d5"></data>
</node>
<node id="concept.promise_to_god">
  <data key="d0">concept.promise_to_god</data>
  <data key="d1">Promise to God</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The promised matter and divine addressee that complete the nature of a vow.</data>
  <data key="d5"></data>
</node>
<node id="concept.religion">
  <data key="d0">concept.religion</data>
  <data key="d1">Religion</data>
  <data key="d2">virtue</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The virtue annexed to justice that renders due worship to God.</data>
  <data key="d5">Treat religion as the positive virtue of divine worship, not as generic creed or confession.</data>
</node>
<node id="concept.sacrament">
  <data key="d0">concept.sacrament</data>
  <data key="d1">Sacrament</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A most spiritual thing of the New Law that causes spiritual grace.</data>
  <data key="d5"></data>
</node>
<node id="concept.sacred_person">
  <data key="d0">concept.sacred_person</data>
  <data key="d1">Sacred Person</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A person consecrated to divine worship and therefore protected against sacrilege.</data>
  <data key="d5"></data>
</node>
<node id="concept.sacred_place">
  <data key="d0">concept.sacred_place</data>
  <data key="d1">Sacred Place</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A place consecrated for divine worship and therefore a possible object of sacrilege.</data>
  <data key="d5"></data>
</node>
<node id="concept.sacred_thing">
  <data key="d0">concept.sacred_thing</data>
  <data key="d1">Sacred Thing</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A thing deputed to divine worship and therefore owed reverence.</data>
  <data key="d5"></data>
</node>
<node id="concept.sacrifice">
  <data key="d0">concept.sacrifice</data>
  <data key="d1">Sacrifice</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">An offering made to God in sign of man's subjection and honor.</data>
  <data key="d5"></data>
</node>
<node id="concept.sacrilege">
  <data key="d0">concept.sacrilege</data>
  <data key="d1">Sacrilege</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The irreverent treatment of a sacred thing, person, place, or sacrament.</data>
  <data key="d5"></data>
</node>
<node id="concept.simony">
  <data key="d0">concept.simony</data>
  <data key="d1">Simony</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The buying or selling of spiritual things or their sacred annexes.</data>
  <data key="d5"></data>
</node>
<node id="concept.sortilege">
  <data key="d0">concept.sortilege</data>
  <data key="d1">Sortilege</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Divination that seeks hidden knowledge by lots or similar acts beyond lawful necessity and reverence.</data>
  <data key="d5"></data>
</node>
<node id="concept.spiritual_action">
  <data key="d0">concept.spiritual_action</data>
  <data key="d1">Spiritual Action</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A spiritual action flowing from grace or disposing to grace and not lawfully saleable.</data>
  <data key="d5"></data>
</node>
<node id="concept.spiritual_office">
  <data key="d0">concept.spiritual_office</data>
  <data key="d1">Spiritual Office</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A sacred office dependent on spiritual things and therefore not lawfully sold.</data>
  <data key="d5"></data>
</node>
<node id="concept.spiritual_thing">
  <data key="d0">concept.spiritual_thing</data>
  <data key="d1">Spiritual Thing</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A spiritual good that cannot be appraised by earthly price and so cannot be lawfully sold.</data>
  <data key="d5"></data>
</node>
<node id="concept.superstition">
  <data key="d0">concept.superstition</data>
  <data key="d1">Superstition</data>
  <data key="d2">vice</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The vice opposed to religion by excess in divine worship.</data>
  <data key="d5"></data>
</node>
<node id="concept.superstitious_observance">
  <data key="d0">concept.superstitious_observance</data>
  <data key="d1">Superstitious Observance</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Superstitious observances that direct human acts by vain signs rather than divine authority.</data>
  <data key="d5"></data>
</node>
<node id="concept.sworn_assertion">
  <data key="d0">concept.sworn_assertion</data>
  <data key="d1">Sworn Assertion</data>
  <data key="d2">object</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The human assertion or promise confirmed by calling God to witness.</data>
  <data key="d5"></data>
</node>
<node id="concept.temptation_of_god">
  <data key="d0">concept.temptation_of_god</data>
  <data key="d1">Temptation of God</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The sin of testing God and thereby showing irreverence toward Him.</data>
  <data key="d5"></data>
</node>
<node id="concept.tithes">
  <data key="d0">concept.tithes</data>
  <data key="d1">Tithes</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">The giving of a fixed proportion for the support of ministers of divine worship.</data>
  <data key="d5"></data>
</node>
<node id="concept.undue_worship_of_true_god">
  <data key="d0">concept.undue_worship_of_true_god</data>
  <data key="d1">Undue Worship of the True God</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">Superstition that offers worship to the true God in an undue mode.</data>
  <data key="d5"></data>
</node>
<node id="concept.vow">
  <data key="d0">concept.vow</data>
  <data key="d1">Vow</data>
  <data key="d2">act_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A promise made to God about something acceptable to Him.</data>
  <data key="d5"></data>
</node>
<node id="concept.written_charm_observance">
  <data key="d0">concept.written_charm_observance</data>
  <data key="d1">Written-Charm Observance</data>
  <data key="d2">sin_type</data>
  <data key="d3">reviewed_seed</data>
  <data key="d4">A superstitious observance that relies on written words or charms apart from due reverence to God.</data>
  <data key="d5"></data>
</node>
