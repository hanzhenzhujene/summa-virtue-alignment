  <data key="d14"></data>
  <data key="d15">st.ii-ii.q080.a001.obj1</data>
  <data key="d16">structural_editorial</data>
  <data key="d17">It would seem that the virtues annexed to justice are unsuitably enumerated Tully [De Invent. ii, 53 reckons six, viz. "religion, piety, gratitude, revenge, observance, truth ." Now revenge is seemingly a species of comm</data>
  <data key="d18">structural</data>
</edge>
<edge source="st.ii-ii.q080.a001" target="concept.justice" id="edge.st.ii-ii.q080.a001.treated_in.concept.justice">
